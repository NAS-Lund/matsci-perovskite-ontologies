@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix obs:     <https://growgraph.dev/ontologies/observation-ontology#> .
@prefix qqval:   <https://growgraph.dev/ontologies/qqval-ontology#> .
@prefix tempo:   <https://growgraph.dev/ontologies/temporal-ontology#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix sosa:    <http://www.w3.org/ns/sosa/> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .


<https://growgraph.dev/ontologies/temporal-ontology> a owl:Ontology ;
    rdfs:label "temporal"@en ;
    dcterms:creator "growgraph.dev" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment
        """Domain-independent vocabulary for process duration, sample aging,
        storage, and time-resolved characterization: process duration and
        elapsed time, aging/exposure/storage/operation process taxonomy,
        time-resolved observable properties, and sample temporal state.
        Originally split out of matsci-ontology (1.3.0); as of 2.0.0 it
        specializes observation-ontology instead of matsci-ontology, since the
        Process, Phenomenon, Observation, QualitativeResult, and
        environment-factor vocabulary it builds on turned out to be
        domain-independent scaffolding, not materials-science-specific.

        Import direction: this ontology imports observation-ontology and
        qqval-ontology only. It does NOT import matsci-ontology, and
        matsci-ontology is free to import this ontology (matsci-ontology
        does so as of 1.5.0, to attach temporal typing to a handful of
        matsci-native individuals/classes -- see matsci-ontology's
        'Temporal typing of matsci-native terms' section).

        2.1.0: updated to follow core-ontology's rename to
        experiment-ontology (prefix core: -> exp:); no vocabulary changes
        of its own.

        3.0.0: renamed ObservableSpectroscopicTemporalProperty to
        ObservableTransientTemporalProperty (technique-neutral). Moved
        matsci/spectroscopy-specific named individuals and environment
        factors to matsci-ontology. Updated to follow experiment-ontology's
        rename to observation-ontology (prefix exp: -> obs:). Relinked
        TimeDependentEffect to obs:Phenomenon instead of
        obs:PhysicalPhenomenon.

        3.1.0: moved tempo:airAgedSampleState and tempo:vacuumAgedSampleState
        to matsci-ontology -- "air" and "vacuum" are materials-science
        storage conditions that had been missed in the 3.0.0 pass that
        moved the rest of the matsci-specific vocabulary out of this
        ontology. The universal SampleTemporalState trio (fresh/aged/
        stored) stays here; domain-specific states are added as siblings
        downstream. Moved materials-science illustrations out of
        rdfs:comment prose and into skos:example on OperationProcess,
        StorageAgingProcess, and ExposureAgingProcess so they read as
        examples rather than scope boundaries."""@en ;
    owl:versionIRI <https://growgraph.dev/ontologies/temporal-ontology/3.1.0> ;
    owl:imports
        <https://growgraph.dev/ontologies/observation-ontology> ,
        <https://growgraph.dev/ontologies/qqval-ontology> ,
        <https://www.w3.org/ns/sosa/sosa.ttl> ;
    owl:versionInfo "3.1.0" .

#################################################################
# Process taxonomy
#################################################################

tempo:TemporalProcess a owl:Class ;
    rdfs:label "Temporal process"@en ;
    rdfs:comment "A process for which duration, elapsed time, temporal order, or time-dependent evolution is explicitly relevant."@en ;
    rdfs:subClassOf obs:Process .

tempo:PostSynthesisProcess a owl:Class ;
    rdfs:label "Post-synthesis process"@en ;
    rdfs:comment "A process performed on a sample after its synthesis or fabrication, including storage, exposure, aging, and post-synthetic treatment."@en ;
    rdfs:subClassOf tempo:TemporalProcess .

tempo:StorageProcess a owl:Class ;
    rdfs:label "Storage process"@en ;
    rdfs:comment "A post-synthesis process in which a sample is kept under specified conditions for a specified duration."@en ;
    rdfs:subClassOf tempo:PostSynthesisProcess .

tempo:ExposureProcess a owl:Class ;
    rdfs:label "Exposure process"@en ;
    rdfs:comment "A process in which a sample is subjected to an environmental, optical, thermal, chemical, or mechanical factor for a specified duration."@en ;
    rdfs:subClassOf tempo:TemporalProcess .

tempo:AgingProcess a owl:Class ;
    rdfs:label "Aging process"@en ;
    rdfs:comment "A time-dependent post-synthesis process in which a sample evolves during storage, exposure, or operation, potentially changing its composition, morphology, structure, or optical properties."@en ;
    rdfs:subClassOf tempo:PostSynthesisProcess .

tempo:StorageAgingProcess a owl:Class ;
    rdfs:label "Storage aging process"@en ;
    rdfs:comment "An aging process in which a sample evolves over time while being stored under specified environmental conditions."@en ;
    skos:example "atmosphere"@en , "humidity"@en , "temperature"@en , "pressure"@en , "storage duration"@en ;
    rdfs:subClassOf tempo:AgingProcess,
                    tempo:StorageProcess .

tempo:ExposureAgingProcess a owl:Class ;
    rdfs:label "Exposure aging process"@en ;
    rdfs:comment "An aging process in which a sample evolves over time while being exposed to an external factor."@en ;
    skos:example "environmental exposure"@en , "optical exposure"@en , "thermal exposure"@en , "chemical exposure"@en , "mechanical exposure"@en ;
    rdfs:subClassOf tempo:AgingProcess,
                    tempo:ExposureProcess .

tempo:OperationProcess a owl:Class ;
    rdfs:label "Operation process"@en ;
    rdfs:comment "A process in which a material, sample, or device is used under functional working conditions."@en ;
    skos:example "illumination"@en , "biasing"@en , "cycling"@en , "charging"@en , "discharging"@en , "device operation"@en ;
    rdfs:subClassOf tempo:TemporalProcess .

tempo:OperationalAgingProcess a owl:Class ;
    rdfs:label "Operational aging process"@en ;
    rdfs:comment "An aging process in which a sample or device evolves over time during operation or use."@en ;
    skos:example "cycling"@en , "illumination"@en , "biasing"@en ;
    rdfs:subClassOf tempo:AgingProcess,
                    tempo:OperationProcess .

#################################################################
# Quantity values, effects, and observation model
#################################################################

tempo:TimeQuantityValue a owl:Class ;
    rdfs:label "Time quantity value"@en ;
    rdfs:comment "A qualified quantity value representing a time, duration, elapsed time, delay, lifetime, time scale, or sample age. It reuses qqval:ApproximateQuantityValue so that exact values, approximate values, ranges, one-sided bounds, and uncertainties can be represented consistently."@en ;
    rdfs:subClassOf qqval:ApproximateQuantityValue .

tempo:TimeDependentEffect a owl:Class ;
    rdfs:label "Time-dependent effect"@en ;
    rdfs:comment "An effect associated with elapsed time during synthesis, storage, aging, exposure, or characterization."@en ;
    rdfs:subClassOf obs:Phenomenon .

tempo:AgingEffect a owl:Class ;
    rdfs:label "Aging effect"@en ;
    rdfs:comment "A time-dependent effect produced or observed after sample aging."@en ;
    rdfs:subClassOf tempo:TimeDependentEffect .

tempo:StorageEffect a owl:Class ;
    rdfs:label "Storage effect"@en ;
    rdfs:comment "A time-dependent effect associated with keeping a sample under specified storage conditions."@en ;
    rdfs:subClassOf tempo:TimeDependentEffect .

tempo:ObservableTemporalProperty a owl:Class ;
    rdfs:label "Observable temporal property"@en ;
    rdfs:comment "An observable property whose value is a time, duration, elapsed time, delay, lifetime, rate-related time scale, or sample age."@en ;
    rdfs:subClassOf sosa:ObservableProperty .

tempo:TemporalObservation a owl:Class ;
    rdfs:label "Temporal observation"@en ;
    rdfs:comment "A quantitative observation whose observed property is temporal and whose result is represented as a time quantity value."@en ;
    rdfs:subClassOf obs:QuantitativeObservation ,
        [
            a owl:Restriction ;
            owl:onProperty sosa:observedProperty ;
            owl:someValuesFrom tempo:ObservableTemporalProperty
        ] ,
        [
            a owl:Restriction ;
            owl:onProperty tempo:hasTemporalQuantityResult ;
            owl:someValuesFrom tempo:TimeQuantityValue
        ] .

tempo:SampleTemporalState a owl:Class ;
    rdfs:label "Sample temporal state"@en ;
    rdfs:comment "A qualitative result describing the temporal status of a sample. Open vocabulary: domain ontologies add domain-specific states as siblings of the universal fresh/aged/stored trio defined here."@en ;
    skos:example "fresh"@en , "aged"@en , "stored"@en , "air-aged"@en , "vacuum-aged"@en ;
    rdfs:subClassOf obs:QualitativeResult .

tempo:ObservableProcessTemporalProperty a owl:Class ;
    rdfs:label "Observable process temporal property"@en ;
    rdfs:comment "A temporal property describing the duration or elapsed time of a process or process step."@en ;
    rdfs:subClassOf tempo:ObservableTemporalProperty .

tempo:ObservableSampleTemporalProperty a owl:Class ;
    rdfs:label "Observable sample temporal property"@en ;
    rdfs:comment "A temporal property describing the age, temporal status, or time-dependent condition of a sample."@en ;
    rdfs:subClassOf tempo:ObservableTemporalProperty .

tempo:ObservableTransientTemporalProperty a owl:Class ;
    rdfs:label "Observable transient temporal property"@en ;
    rdfs:comment "A temporal property characterizing an event-triggered, finely time-resolved transient response of a process or system, independent of measurement technique."@en ;
    rdfs:subClassOf tempo:ObservableTemporalProperty .

tempo:TimeConditionValue a owl:Class ;
    rdfs:label "Time condition value"@en ;
    rdfs:comment "A quantitative condition value representing a temporal condition, such as storage duration, aging time, exposure duration, delay time, or sample age. It is also a time quantity value and therefore reuses qqval qualifiers for exact, approximate, range, bound, or uncertainty expressions."@en ;
    rdfs:subClassOf obs:QuantitativeConditionValue,
                    tempo:TimeQuantityValue .

#################################################################
# Object properties
#################################################################

tempo:hasDuration a owl:ObjectProperty ;
    rdfs:label "has duration"@en ;
    rdfs:comment "Links a process to a time quantity value representing its duration."@en ;
    rdfs:domain obs:Process ;
    rdfs:range tempo:TimeQuantityValue .

tempo:hasElapsedTime a owl:ObjectProperty ;
    rdfs:label "has elapsed time"@en ;
    rdfs:comment "Links an entity to a time quantity value representing elapsed time since a relevant reference event."@en ;
    rdfs:range tempo:TimeQuantityValue .

tempo:hasSampleAge a owl:ObjectProperty ;
    rdfs:label "has sample age"@en ;
    rdfs:comment "Links a concrete sample to a time quantity value representing the time elapsed since its synthesis, fabrication, deposition, or another stated reference event."@en ;
    rdfs:domain sosa:Sample ;
    rdfs:range tempo:TimeQuantityValue ;
    rdfs:subPropertyOf tempo:hasElapsedTime .

tempo:hasTemporalQuantityResult a owl:ObjectProperty ;
    rdfs:label "has temporal quantity result"@en ;
    rdfs:comment "Links a temporal observation to a time quantity value."@en ;
    rdfs:domain tempo:TemporalObservation ;
    rdfs:range tempo:TimeQuantityValue ;
    rdfs:subPropertyOf obs:hasQuantityResult .

tempo:hasObservationTimePoint a owl:ObjectProperty ;
    rdfs:label "has observation time point"@en ;
    rdfs:comment "Links an observation to a time quantity value representing the time point or delay at which the observation result was recorded."@en ;
    rdfs:domain obs:Observation ;
    rdfs:range tempo:TimeQuantityValue ;
    rdfs:subPropertyOf tempo:hasElapsedTime .

tempo:hasTemporalReferenceProcess a owl:ObjectProperty ;
    rdfs:label "has temporal reference process"@en ;
    rdfs:comment "Links a temporal value, observation, sample, or process to the process used as the reference point for elapsed time, such as synthesis, deposition, storage start, aging start, excitation, or measurement start."@en ;
    rdfs:range obs:Process .

tempo:hasStorageCondition a owl:ObjectProperty ;
    rdfs:label "has storage condition"@en ;
    rdfs:comment "Links a storage or aging process to a reified condition, such as atmosphere, pressure, humidity, temperature, or storage duration."@en ;
    rdfs:domain tempo:StorageProcess ;
    rdfs:range obs:EnvironmentCondition ;
    rdfs:subPropertyOf obs:hasProcessCondition .

tempo:hasTimeDependentEffect a owl:ObjectProperty ;
    rdfs:label "has time-dependent effect"@en ;
    rdfs:comment "Links a temporal process to an effect associated with elapsed time."@en ;
    rdfs:domain tempo:TemporalProcess ;
    rdfs:range tempo:TimeDependentEffect .

tempo:affectsObservableProperty a owl:ObjectProperty ;
    rdfs:label "affects observable property"@en ;
    rdfs:comment "Links a time-dependent effect to the observable property whose value or qualitative state changes."@en ;
    rdfs:domain tempo:TimeDependentEffect ;
    rdfs:range sosa:ObservableProperty .

#################################################################
# Temporal environment factors
#
# Typed obs:EnvironmentFactor and linked via obs:broaderEnvironmentFactor
# (both defined in observation-ontology as generic, domain-independent
# infrastructure). The top-level "time" factor these chain up to is
# obs:time.
#################################################################

tempo:duration a owl:NamedIndividual, obs:EnvironmentFactor ;
    rdfs:label "duration"@en ;
    rdfs:comment "General temporal extent of a process or interval."@en ;
    obs:broaderEnvironmentFactor obs:time .

tempo:storageDuration a owl:NamedIndividual, obs:EnvironmentFactor ;
    rdfs:label "storage duration"@en ;
    rdfs:comment "Duration for which a sample is stored under specified conditions."@en ;
    obs:broaderEnvironmentFactor tempo:duration .

tempo:agingTime a owl:NamedIndividual, obs:EnvironmentFactor ;
    rdfs:label "aging time"@en ;
    rdfs:comment "Elapsed time during which a sample ages under storage, exposure, operational, or other time-dependent conditions."@en ;
    obs:broaderEnvironmentFactor tempo:duration .

tempo:exposureDuration a owl:NamedIndividual, obs:EnvironmentFactor ;
    rdfs:label "exposure duration"@en ;
    rdfs:comment "Duration for which a sample is exposed to an environmental, optical, thermal, chemical, or mechanical factor."@en ;
    obs:broaderEnvironmentFactor tempo:duration .

tempo:sampleAge a owl:NamedIndividual, obs:EnvironmentFactor ;
    rdfs:label "sample age"@en ;
    rdfs:comment "Elapsed time between sample synthesis or fabrication and a later process or observation."@en ;
    obs:broaderEnvironmentFactor obs:time .

tempo:measurementDelayTime a owl:NamedIndividual, obs:EnvironmentFactor ;
    rdfs:label "measurement delay time"@en ;
    rdfs:comment "Delay time between a reference event and a measurement."@en ;
    obs:broaderEnvironmentFactor obs:time .

#################################################################
# Temporal observable property vocabulary
#
# Domain-neutral individuals only. Matsci/spectroscopy-specific
# vocabulary is minted in matsci-ontology and typed against these
# classes in matsci's 'Temporal typing of matsci-native terms' section.
#################################################################

tempo:storageDurationProperty a owl:NamedIndividual, tempo:ObservableProcessTemporalProperty ;
    rdfs:label "storage duration"@en .

tempo:agingTimeProperty a owl:NamedIndividual, tempo:ObservableSampleTemporalProperty ;
    rdfs:label "aging time"@en .

tempo:sampleAgeProperty a owl:NamedIndividual, tempo:ObservableSampleTemporalProperty ;
    rdfs:label "sample age"@en .

tempo:exposureDurationProperty a owl:NamedIndividual, tempo:ObservableProcessTemporalProperty ;
    rdfs:label "exposure duration"@en .

#################################################################
# Sample temporal state controlled vocabulary
#
# Universal trio only. Domain-specific storage/aging states (e.g.
# matsci-ontology's air-aged / vacuum-aged) are minted as siblings of
# this class downstream -- see matsci-ontology's "Environment factor and
# condition-value individuals" section.
#################################################################

tempo:freshSampleState a owl:NamedIndividual, tempo:SampleTemporalState ;
    rdfs:label "fresh sample"@en ;
    dcterms:alternative "day 0", "pristine sample" .

tempo:agedSampleState a owl:NamedIndividual, tempo:SampleTemporalState ;
    rdfs:label "aged sample"@en .

tempo:storedSampleState a owl:NamedIndividual, tempo:SampleTemporalState ;
    rdfs:label "stored sample"@en .

tempo:sampleTemporalStateProperty a owl:NamedIndividual, tempo:ObservableSampleTemporalProperty ;
    rdfs:label "sample temporal state"@en .
