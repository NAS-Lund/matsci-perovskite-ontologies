@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix obs:     <https://growgraph.dev/ontologies/observation-ontology#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix sosa:    <http://www.w3.org/ns/sosa/> .
@prefix tempo:   <https://growgraph.dev/ontologies/temporal-ontology#> .

#################################################################
# Shapes graph header
#
# Closed-world validation companion to temporal-ontology. Mirrors the
# someValuesFrom restrictions declared on tempo:TemporalObservation and
# tempo:QualitativeEntityTemporalObservation, the same way qqval-shapes/
# observation-shapes mirror their respective ontologies' OWL
# restrictions. Unlike those two, most of temporal-ontology's other
# classes (TemporalProcess, TimeDependentEffect, ...) carry no qualified
# OWL restrictions of their own to mirror -- they are open extension
# points, not closed structural shapes -- so this file stays small.
#
# Apply against the data graph together with observation-shapes and
# qqval-shapes in scope, since TemporalObservation/
# QualitativeEntityTemporalObservation instances are also validated against
# obs:QuantitativeObservationShape / obs:QualitativeObservationShape via
# SHACL's subclass-aware sh:targetClass matching.
#
# Requires RDFS inference (pyshacl -i rdfs) on the data graph:
# tempo:hasTemporalQuantityResult / tempo:hasEntityTemporalStateResult are
# rdfs:subPropertyOf obs:hasQuantityResult / obs:hasQualitativeResult.
# Without an inference pass, asserting only the more specific tempo:
# property (the extraction-pipeline-expected behavior) fails
# observation-shapes.ttl's class-level MinCountConstraintComponent checks,
# since SHACL Core does not itself follow rdfs:subPropertyOf.
#################################################################

<https://growgraph.dev/ontologies/temporal-shapes> a owl:Ontology ;
    rdfs:label "temporal shapes"@en ;
    dcterms:creator "growgraph.dev" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment
        """SHACL shapes mirroring the OWL someValuesFrom restrictions
        declared on tempo:TemporalObservation and
        tempo:QualitativeEntityTemporalObservation in temporal-ontology
        (>= 4.0.0).

        1.0.0: initial version.

        1.1.0: renamed tempo:EntityTemporalObservationShape ->
        QualitativeEntityTemporalObservationShape, following
        temporal-ontology 4.1.0's tempo:EntityTemporalObservation ->
        QualitativeEntityTemporalObservation / hasEntityTemporalResult ->
        hasEntityTemporalStateResult rename."""@en ;
    owl:versionIRI <https://growgraph.dev/ontologies/temporal-shapes/1.1.0> ;
    owl:versionInfo "1.1.0" .

#################################################################
# TemporalObservation — observed property and result must be temporal
#################################################################

tempo:TemporalObservationShape a sh:NodeShape ;
    sh:targetClass tempo:TemporalObservation ;
    sh:property
        [ sh:path sosa:observedProperty ;
            sh:minCount 1 ;
            sh:class tempo:ObservableTemporalProperty ;
            sh:message "TemporalObservation requires at least one sosa:observedProperty of type tempo:ObservableTemporalProperty."@en
        ] ,
        [ sh:path tempo:hasTemporalQuantityResult ;
            sh:minCount 1 ;
            sh:class tempo:TimeQuantityValue ;
            sh:message "TemporalObservation requires at least one tempo:hasTemporalQuantityResult whose value is a tempo:TimeQuantityValue."@en
        ] .

#################################################################
# QualitativeEntityTemporalObservation — entity-scoped qualitative observation
#################################################################

tempo:QualitativeEntityTemporalObservationShape a sh:NodeShape ;
    sh:targetClass tempo:QualitativeEntityTemporalObservation ;
    sh:property
        [ sh:path sosa:observedProperty ;
            sh:minCount 1 ;
            sh:class tempo:ObservableEntityTemporalProperty ;
            sh:message "QualitativeEntityTemporalObservation requires at least one sosa:observedProperty of type tempo:ObservableEntityTemporalProperty."@en
        ] ,
        [ sh:path tempo:hasEntityTemporalStateResult ;
            sh:minCount 1 ;
            sh:class tempo:EntityTemporalState ;
            sh:message "QualitativeEntityTemporalObservation requires at least one tempo:hasEntityTemporalStateResult whose value is a tempo:EntityTemporalState."@en
        ] .
