@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix matsci:  <https://growgraph.dev/ontologies/matsci-ontology#> .
@prefix obs:     <https://growgraph.dev/ontologies/observation-ontology#> .
@prefix qqval:   <https://growgraph.dev/ontologies/qqval-ontology#> .
@prefix tempo:   <https://growgraph.dev/ontologies/temporal-ontology#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix qudt:    <http://qudt.org/schema/qudt/> .
@prefix unit:    <http://qudt.org/vocab/unit/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sosa:    <http://www.w3.org/ns/sosa/> .
@prefix ssn:     <http://www.w3.org/ns/ssn/> .
@prefix obo:     <http://purl.obolibrary.org/obo/> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix om:      <http://www.ontology-of-units-of-measure.org/resource/om-2/> .


<https://growgraph.dev/ontologies/matsci-ontology> a owl:Ontology ;
    rdfs:label "matsci"@en ;
    dcterms:creator "growgraph.dev" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment
        """General materials-science ontology split from perovOntology.
        It contains concepts and relations reusable across materials-science
        domains.

        As of 2.0.0, the domain-independent Process/Observation/condition
        scaffolding (Process, Observation, QuantitativeObservation,
        QualitativeObservation, PhysicalPhenomenon, QualitativeResult, the
        ConditionValue/Condition/ConditionFactor triad, and
        the object/datatype properties gluing them together) has been
        nucleated out into core-ontology, which this ontology imports.
        matsci-ontology now supplies only the materials-science-specific
        vocabulary layered on top of that scaffolding.

        Temporal/aging vocabulary (process duration, entity aging,
        storage, time-resolved characterization) remains factored out into
        temporal-ontology. Unlike in 1.4.0, this ontology now imports
        temporal-ontology (temporal-ontology itself depends only on
        observation-ontology, not on matsci-ontology, so the dependency graph
        stays acyclic); this lets matsci-native individuals and classes
        carry their temporal typing directly here instead of via the
        supplementary-assertions pattern used previously -- see the
        'Temporal typing of matsci-native terms' section at the end
        of this file.

        2.1.0: updated to follow core-ontology's rename to
        experiment-ontology (prefix core: -> exp:); no vocabulary changes
        of its own.

        2.2.0: updated to follow experiment-ontology's rename to
        observation-ontology (prefix exp: -> obs:). Absorbed
        matsci/spectroscopy-specific temporal vocabulary moved out of
        temporal-ontology 3.0.0 (environment factors, process/transient
        temporal observable properties). Expanded temporal typing section.

        2.3.0: absorbed matsci:airAgedSampleState and
        matsci:vacuumAgedSampleState, moved out of temporal-ontology 3.1.0
        -- these are materials-science storage conditions, not universal
        sample states, and had been missed in the 3.0.0 pass that moved
        the rest of the matsci-specific temporal vocabulary here.

        3.0.0 (breaking): follows observation-ontology 4.0.0's and
        temporal-ontology 4.0.0's renames. obs:EnvironmentFactor/
        EnvironmentCondition are now obs:ConditionFactor/Condition;
        retyped matsci:atmosphere/humidity/temperature/processDuration/
        synthesisDuration/assemblyDuration/pulseDuration accordingly and
        switched their obs:broaderEnvironmentFactor links to skos:broader.
        tempo:SampleTemporalState is now tempo:EntityTemporalState; renamed
        matsci:airAgedSampleState/vacuumAgedSampleState to
        matsci:airAgedEntityState/vacuumAgedEntityState to match. Added
        matsci:hasInputSample/hasOutputSample as sosa:Sample-narrowed
        convenience subproperties of obs:hasInputEntity/hasOutputEntity
        (which replaced obs:hasInputSample/hasOutputSample at the
        domain-neutral layer), so existing matsci-flavored usage keeps its
        familiar name; updated matsci:hasInputMaterial/hasOutputMaterial's
        rdfs:comment cross-references accordingly.

        Extension contract: matsci-ontology is itself the extension layer
        for observation-ontology/temporal-ontology -- it subclasses
        obs:Process/obs:Phenomenon/tempo:TemporalProcess/
        tempo:ObservableTemporalProperty and subproperties the generic
        Entity-of-Interest properties, exactly the pattern a new domain
        ontology (economics, clinical, etc.) would follow at the same
        layer. matsci:Material, matsci:MaterialRole, and the various
        *Method/*Process/*Value controlled vocabularies here are open:
        further materials-science-specific individuals and siblings are
        expected."""@en ;
    owl:versionIRI <https://growgraph.dev/ontologies/matsci-ontology/3.0.0> ;
    owl:imports
        <https://growgraph.dev/ontologies/observation-ontology> ,
        <https://growgraph.dev/ontologies/temporal-ontology> ,
        <https://www.w3.org/ns/sosa/sosa.ttl> ,
        <http://www.w3.org/ns/ssn/> ,
        <http://qudt.org/2.1/schema/facade/qudt> ,
        <http://purl.obolibrary.org/obo/bfo.owl> ,
        <http://qudt.org/2.1/vocab/unit> ,
        <https://growgraph.dev/ontologies/qqval-ontology> ;
    owl:versionInfo "3.0.0" .

#################################################################
# Core classes
#################################################################

matsci:Material a owl:Class ;
    rdfs:label "Material"@en ;
    rdfs:comment "A material kind or material concept instantiated by concrete samples."@en .

matsci:Impurity a owl:Class ;
    rdfs:label "Impurity"@en ;
    rdfs:subClassOf matsci:Material .

matsci:LuminescentImpurity a owl:Class ;
    rdfs:label "Luminescent impurity"@en ;
    rdfs:subClassOf matsci:Impurity .

matsci:MaterialRole a owl:Class ;
    rdfs:label "Material role"@en ;
    rdfs:comment
        """A functional role that a material plays within a specific process
        context.  Inheres in the material bearer and is realized during the
        process in which that material is used.
        Grounded in BFO Role (obo:BFO_0000023)."""@en ;
    rdfs:subClassOf obo:BFO_0000023 .

matsci:SolventRole a owl:Class ;
    rdfs:label "Solvent role"@en ;
    rdfs:comment
        "Role realized when a material dissolves or disperses another substance in a synthesis process."@en ;
    rdfs:subClassOf matsci:MaterialRole .

matsci:AntisolventRole a owl:Class ;
    rdfs:label "Antisolvent role"@en ;
    rdfs:comment
        "Role realized when a material triggers precipitation by reducing solubility of a target species."@en ;
    rdfs:subClassOf matsci:MaterialRole .

matsci:LigandRole a owl:Class ;
    rdfs:label "Ligand role"@en ;
    rdfs:comment
        "Role realized when a material coordinates to a surface or metal centre in a synthesis process."@en ;
    rdfs:subClassOf matsci:MaterialRole .

matsci:Application a owl:Class ;
    rdfs:label "Application"@en .

matsci:OptoelectronicApplication a owl:Class ;
    rdfs:label "Optoelectronic application"@en ;
    rdfs:subClassOf matsci:Application .

matsci:QuantumConfinement a owl:Class ;
    rdfs:label "Quantum confinement"@en ;
    rdfs:comment
        """A disposition of a nanocrystal whereby quantum mechanical boundary
        conditions restrict charge-carrier wavefunctions.  Realised during
        optical characterization.
        Grounded in BFO Disposition (obo:BFO_0000016)."""@en ;
    rdfs:subClassOf obs:PhysicalPhenomenon ,
                    obo:BFO_0000016 .

matsci:RedShift a owl:Class ;
    rdfs:label "Red shift"@en ;
    rdfs:subClassOf obs:PhysicalPhenomenon .

matsci:PhotonPropagationEffect a owl:Class ;
    rdfs:label "Photon propagation effect"@en ;
    rdfs:subClassOf obs:PhysicalPhenomenon .

matsci:Equipment a owl:Class ;
    rdfs:label "Equipment"@en ;
    rdfs:comment
        "Generic scientific equipment used in synthesis, sampling, processing, or characterization workflows."@en ;
    rdfs:subClassOf ssn:System .

matsci:ProcessingEquipment a owl:Class ;
    rdfs:label "Processing equipment"@en ;
    rdfs:subClassOf matsci:Equipment .

matsci:ActuatingEquipment a owl:Class ;
    rdfs:label "Actuating equipment"@en ;
    rdfs:subClassOf matsci:ProcessingEquipment, sosa:Actuator .

matsci:CharacterizationEquipment a owl:Class ;
    rdfs:label "Characterization equipment"@en ;
    rdfs:comment "Scientific equipment used in a characterization process."@en ;
    rdfs:subClassOf matsci:Equipment .

matsci:CharacterizationSensor a owl:Class ;
    rdfs:label "Characterization sensor"@en ;
    rdfs:subClassOf matsci:CharacterizationEquipment, sosa:Sensor .

#################################################################
# Procedures and process types
#################################################################

matsci:SynthesisMethod a owl:Class ;
    rdfs:label "Synthesis method"@en ;
    rdfs:comment "A synthesis procedure type."@en ;
    rdfs:subClassOf sosa:Procedure .

matsci:AssemblyMethod a owl:Class ;
    rdfs:label "Assembly method"@en ;
    rdfs:comment "An assembly procedure type."@en ;
    rdfs:subClassOf sosa:Procedure .

matsci:CharacterizationMethod a owl:Class ;
    rdfs:label "Characterization method"@en ;
    rdfs:comment "A characterization procedure type."@en ;
    rdfs:subClassOf sosa:Procedure .

matsci:OpticalCharacterizationMethod a owl:Class ;
    rdfs:label "Optical characterization method"@en ;
    rdfs:subClassOf matsci:CharacterizationMethod .

matsci:ElectronicCharacterizationMethod a owl:Class ;
    rdfs:label "Electronic characterization method"@en ;
    rdfs:subClassOf matsci:CharacterizationMethod .

matsci:StructuralCharacterizationMethod a owl:Class ;
    rdfs:label "Structural characterization method"@en ;
    rdfs:subClassOf matsci:CharacterizationMethod .

matsci:SelfAssemblyTechnique a owl:Class ;
    rdfs:label "Self-assembly technique"@en ;
    rdfs:comment "A procedure type used to organize nanocrystals into superlattices."@en ;
    rdfs:subClassOf matsci:AssemblyMethod .

matsci:ChemicalTransformationType a owl:Class ;
    rdfs:label "Chemical transformation type"@en ;
    rdfs:comment
        "A transformation procedure type, such as anion exchange, cation exchange, doping, or ligand exchange."@en ;
    rdfs:subClassOf sosa:Procedure .

#################################################################
# Process execution layer
#
# matsci:Process itself (and the generic Observation/PhysicalPhenomenon
# scaffolding it participates in) now lives in observation-ontology as
# obs:Process. The concrete process types below are the
# materials-science-specific subclasses of obs:Process.
#################################################################

matsci:SynthesisProcess a owl:Class ;
    rdfs:label "Synthesis process"@en ;
    rdfs:comment "A concrete execution of a synthesis method."@en ;
    rdfs:subClassOf obs:Process .

matsci:AssemblyProcess a owl:Class ;
    rdfs:label "Assembly process"@en ;
    rdfs:comment "A concrete execution of an assembly method."@en ;
    rdfs:subClassOf obs:Process .

matsci:CharacterizationProcess a owl:Class ;
    rdfs:label "Characterization process"@en ;
    rdfs:comment
        "A concrete execution of a characterization method that generates one or more observations."@en ;
    rdfs:subClassOf obs:Process .

matsci:ChemicalTransformation a owl:Class ;
    rdfs:label "Chemical transformation"@en ;
    rdfs:comment
        "A concrete transformation step occurring during a synthesis or post-synthetic process."@en ;
    rdfs:subClassOf obs:Process .

#################################################################
# Samples and morphology
#################################################################

matsci:BulkSample a owl:Class ;
    rdfs:label "Bulk sample"@en ;
    rdfs:comment "Concrete bulk material sample."@en ;
    rdfs:subClassOf sosa:Sample .

matsci:NanocrystalSample a owl:Class ;
    rdfs:label "Nanocrystal sample"@en ;
    dcterms:alternative "NC", "QD", "nanocrystal", "quantum dot" ;
    rdfs:comment "Concrete nanocrystal sample."@en ;
    rdfs:subClassOf sosa:Sample .

matsci:SuperlatticeSample a owl:Class ;
    rdfs:label "Superlattice sample"@en ;
    dcterms:alternative "SL", "superlattice" ;
    rdfs:comment "Concrete superlattice sample."@en ;
    rdfs:subClassOf sosa:Sample .

matsci:NanocrystalSuperlatticeSample a owl:Class ;
    rdfs:label "Nanocrystal superlattice sample"@en ;
    rdfs:comment
        "A structured arrangement of nanocrystal samples that exhibits collective properties."@en ;
    rdfs:subClassOf matsci:SuperlatticeSample .

matsci:MorphologyState a owl:Class ;
    rdfs:label "Morphology state"@en ;
    rdfs:comment
        """An intrinsic quality of a sample describing its morphological
        characteristics.  Inheres in the sample bearer.
        Grounded in BFO Quality (obo:BFO_0000019)."""@en ;
    rdfs:subClassOf obo:BFO_0000019 .

matsci:NanocrystalMorphologyState a owl:Class ;
    rdfs:label "Nanocrystal morphology state"@en ;
    rdfs:subClassOf matsci:MorphologyState .

matsci:SuperlatticeMorphologyState a owl:Class ;
    rdfs:label "Superlattice morphology state"@en ;
    rdfs:subClassOf matsci:MorphologyState .

matsci:AssemblyStructure a owl:Class ;
    rdfs:label "Assembly structure"@en ;
    rdfs:subClassOf matsci:SuperlatticeMorphologyState .

#################################################################
# Qualitative result vocabulary
#
# matsci:QualitativeResult itself now lives in observation-ontology as
# obs:QualitativeResult. The classes below are its
# materials-science-specific subclasses.
#################################################################

matsci:DimensionalityValue a owl:Class ;
    rdfs:label "Dimensionality value"@en ;
    rdfs:subClassOf obs:QualitativeResult .

matsci:PackingMotifValue a owl:Class ;
    rdfs:label "Packing motif value"@en ;
    rdfs:subClassOf obs:QualitativeResult .

matsci:SuperlatticeSymmetryValue a owl:Class ;
    rdfs:label "Superlattice symmetry value"@en ;
    rdfs:subClassOf obs:QualitativeResult .

matsci:FacetExposureValue a owl:Class ;
    rdfs:label "Facet exposure value"@en ;
    rdfs:subClassOf obs:QualitativeResult .

matsci:ShapeValue a owl:Class ;
    rdfs:label "Shape value"@en ;
    rdfs:subClassOf obs:QualitativeResult .

#################################################################
# Observation model
#
# matsci:Observation, QuantitativeObservation, and QualitativeObservation
# now live in observation-ontology (obs:Observation, obs:QuantitativeObservation,
# obs:QualitativeObservation). Only the materials-science-specific
# ObservableProperty subclasses remain here.
#################################################################

matsci:ObservableMaterialProperty a owl:Class ;
    rdfs:label "Observable material property"@en ;
    rdfs:subClassOf sosa:ObservableProperty .

matsci:ObservableMorphologyProperty a owl:Class ;
    rdfs:label "Observable morphology property"@en ;
    rdfs:subClassOf sosa:ObservableProperty .

matsci:ObservableMaterialProperty owl:disjointWith matsci:ObservableMorphologyProperty .

#################################################################
# Object properties
#################################################################

matsci:describesMaterial a owl:ObjectProperty ;
    rdfs:label "describes material"@en ;
    rdfs:comment "Links a concrete sample to the material concept it instantiates."@en ;
    rdfs:domain sosa:Sample ;
    rdfs:range matsci:Material .

matsci:hasApplication a owl:ObjectProperty ;
    rdfs:label "has application"@en ;
    rdfs:domain matsci:Material ;
    rdfs:range matsci:Application .

matsci:exhibitsPhenomenon a owl:ObjectProperty ;
    rdfs:label "exhibits phenomenon"@en ;
    rdfs:domain sosa:Sample ;
    rdfs:range obs:PhysicalPhenomenon .

matsci:exhibitsQuantumConfinement a owl:ObjectProperty ;
    rdfs:label "exhibits quantum confinement"@en ;
    rdfs:domain matsci:NanocrystalSample ;
    rdfs:range matsci:QuantumConfinement ;
    rdfs:subPropertyOf matsci:exhibitsPhenomenon .

matsci:hasPhotonPropagationEffect a owl:ObjectProperty ;
    rdfs:label "has photon propagation effect"@en ;
    rdfs:domain matsci:NanocrystalSuperlatticeSample ;
    rdfs:range matsci:PhotonPropagationEffect ;
    rdfs:subPropertyOf matsci:exhibitsPhenomenon .

matsci:hasMorphology a owl:ObjectProperty ;
    rdfs:label "has morphology"@en ;
    rdfs:domain sosa:Sample ;
    rdfs:range matsci:MorphologyState .

matsci:hasNanocrystalMorphology a owl:ObjectProperty ;
    rdfs:label "has nanocrystal morphology"@en ;
    rdfs:domain matsci:NanocrystalSample ;
    rdfs:range matsci:NanocrystalMorphologyState ;
    rdfs:subPropertyOf matsci:hasMorphology .

matsci:hasSuperlatticeMorphology a owl:ObjectProperty ;
    rdfs:label "has superlattice morphology"@en ;
    rdfs:domain matsci:SuperlatticeSample ;
    rdfs:range matsci:SuperlatticeMorphologyState ;
    rdfs:subPropertyOf matsci:hasMorphology .

matsci:hasDimensionalityValue a owl:ObjectProperty ;
    rdfs:label "has dimensionality value"@en ;
    rdfs:domain matsci:MorphologyState ;
    rdfs:range matsci:DimensionalityValue .

matsci:hasShapeValue a owl:ObjectProperty ;
    rdfs:label "has shape value"@en ;
    rdfs:domain matsci:MorphologyState ;
    rdfs:range matsci:ShapeValue .

matsci:hasFacetExposureValue a owl:ObjectProperty ;
    rdfs:label "has facet exposure value"@en ;
    rdfs:domain matsci:MorphologyState ;
    rdfs:range matsci:FacetExposureValue .

matsci:hasPackingMotifValue a owl:ObjectProperty ;
    rdfs:label "has packing motif value"@en ;
    rdfs:domain matsci:MorphologyState ;
    rdfs:range matsci:PackingMotifValue .

matsci:hasSuperlatticeSymmetryValue a owl:ObjectProperty ;
    rdfs:label "has superlattice symmetry value"@en ;
    rdfs:domain matsci:SuperlatticeMorphologyState ;
    rdfs:range matsci:SuperlatticeSymmetryValue .

matsci:hasEdgeLength a owl:ObjectProperty ;
    rdfs:label "has edge length"@en ;
    rdfs:comment
        "Links a nanocrystal morphology state to a quantity value for edge length.  The value may be a qqval:ApproximateQuantityValue when the measurement carries an epistemic qualifier."@en ;
    rdfs:domain matsci:NanocrystalMorphologyState ;
    rdfs:range qudt:QuantityValue .

matsci:hasThickness a owl:ObjectProperty ;
    rdfs:label "has thickness"@en ;
    rdfs:comment
        "Links a nanocrystal morphology state to a quantity value for thickness.  The value may be a qqval:ApproximateQuantityValue when the measurement carries an epistemic qualifier."@en ;
    rdfs:domain matsci:NanocrystalMorphologyState ;
    rdfs:range qudt:QuantityValue .

matsci:hasValueRange a owl:ObjectProperty ;
    rdfs:label "has value range"@en ;
    rdfs:comment
        """Links a morphology state to a quantitative interval represented as
        a qqval:QuantityRange node (bounds are independent qudt:QuantityValue
        nodes).  For compact same-unit ranges, prefer an observation result
        typed as qqval:ApproximateQuantityValue with qqval:Range qualifier."""@en ;
    rdfs:domain matsci:MorphologyState ;
    rdfs:range qqval:QuantityRange .

matsci:derivedFromObservation a owl:ObjectProperty ;
    rdfs:label "derived from observation"@en ;
    rdfs:comment "Links an interpreted state description to the observation supporting it."@en ;
    rdfs:domain matsci:MorphologyState ;
    rdfs:range obs:Observation .

matsci:usesSelfAssemblyTechnique a owl:ObjectProperty ;
    rdfs:label "uses self-assembly technique"@en ;
    rdfs:domain matsci:AssemblyProcess ;
    rdfs:range matsci:SelfAssemblyTechnique .

matsci:hasInputMaterial a owl:ObjectProperty ;
    rdfs:label "has input material"@en ;
    rdfs:comment
        "Links a process to the abstract material kind it consumes, for recipe or provenance tracking.  For concrete sample-level traceability use matsci:hasInputSample."@en ;
    rdfs:domain obs:Process ;
    rdfs:range matsci:Material .

matsci:hasOutputMaterial a owl:ObjectProperty ;
    rdfs:label "has output material"@en ;
    rdfs:comment
        "Links a process to the abstract material kind it targets as output.  For the concrete produced sample use matsci:hasOutputSample."@en ;
    rdfs:domain obs:Process ;
    rdfs:range matsci:Material .

matsci:hasInputSample a owl:ObjectProperty ;
    rdfs:label "has input sample"@en ;
    rdfs:comment
        "Sample-flavored convenience subproperty of obs:hasInputEntity, narrowed to sosa:Sample.  Use this at the matsci layer instead of obs:hasInputEntity directly."@en ;
    rdfs:domain obs:Process ;
    rdfs:range sosa:Sample ;
    rdfs:subPropertyOf obs:hasInputEntity .

matsci:hasOutputSample a owl:ObjectProperty ;
    rdfs:label "has output sample"@en ;
    rdfs:comment
        "Sample-flavored convenience subproperty of obs:hasOutputEntity, narrowed to sosa:Sample.  Use this at the matsci layer instead of obs:hasOutputEntity directly."@en ;
    rdfs:domain obs:Process ;
    rdfs:range sosa:Sample ;
    rdfs:subPropertyOf obs:hasOutputEntity .

matsci:usedProcessingEquipment a owl:ObjectProperty ;
    rdfs:label "used processing equipment"@en ;
    rdfs:domain obs:Process ;
    rdfs:range matsci:Equipment .

matsci:usedCharacterizationEquipment a owl:ObjectProperty ;
    rdfs:label "used characterization equipment"@en ;
    rdfs:domain matsci:CharacterizationProcess ;
    rdfs:range matsci:CharacterizationEquipment ;
    rdfs:subPropertyOf matsci:usedProcessingEquipment .

matsci:generatedObservation a owl:ObjectProperty ;
    rdfs:label "generated observation"@en ;
    rdfs:domain matsci:CharacterizationProcess ;
    rdfs:range obs:Observation .

matsci:usedSolvent a owl:ObjectProperty ;
    rdfs:label "used solvent"@en ;
    rdfs:comment
        "Links a synthesis process to the material playing the solvent role in that process."@en ;
    rdfs:domain matsci:SynthesisProcess ;
    rdfs:range matsci:Material .

matsci:usedAntisolvent a owl:ObjectProperty ;
    rdfs:label "used antisolvent"@en ;
    rdfs:comment
        "Links a synthesis process to the material playing the antisolvent role in that process."@en ;
    rdfs:domain matsci:SynthesisProcess ;
    rdfs:range matsci:Material .

matsci:usedLigand a owl:ObjectProperty ;
    rdfs:label "used ligand"@en ;
    rdfs:comment
        "Links a synthesis process to the material playing the ligand role in that process."@en ;
    rdfs:domain matsci:SynthesisProcess ;
    rdfs:range matsci:Material .

matsci:hasRole a owl:ObjectProperty ;
    rdfs:label "has role"@en ;
    rdfs:comment
        """Asserts that a material has a capacity to play a given functional
        role.  For context-specific role assignments, prefer the process-level
        shortcut properties (usedSolvent, usedAntisolvent, usedLigand)."""@en ;
    rdfs:domain matsci:Material ;
    rdfs:range matsci:MaterialRole .

matsci:hasTransformationStep a owl:ObjectProperty ;
    rdfs:label "has transformation step"@en ;
    rdfs:comment "Links a concrete process to a concrete chemical transformation step."@en ;
    rdfs:domain obs:Process ;
    rdfs:range matsci:ChemicalTransformation .

matsci:hasTransformationType a owl:ObjectProperty ;
    rdfs:label "has transformation type"@en ;
    rdfs:comment
        "Links a concrete chemical transformation to the transformation procedure type it instantiates."@en ;
    rdfs:domain matsci:ChemicalTransformation ;
    rdfs:range matsci:ChemicalTransformationType .

matsci:transformsSample a owl:ObjectProperty ;
    rdfs:label "transforms sample"@en ;
    rdfs:comment "Links a chemical transformation step to the concrete sample it operates on."@en ;
    rdfs:domain matsci:ChemicalTransformation ;
    rdfs:range sosa:Sample .

matsci:producesAssemblyStructure a owl:ObjectProperty ;
    rdfs:label "produces assembly structure"@en ;
    rdfs:domain matsci:AssemblyProcess ;
    rdfs:range matsci:AssemblyStructure .

matsci:hasConstituentNanocrystalSample a owl:ObjectProperty ;
    rdfs:label "has constituent nanocrystal sample"@en ;
    rdfs:domain matsci:SuperlatticeSample ;
    rdfs:range matsci:NanocrystalSample .

matsci:isCompatibleWithSolvent a owl:ObjectProperty ;
    rdfs:label "is compatible with solvent"@en ;
    rdfs:comment
        "Links a nanocrystal superlattice sample to a material that acts as a compatible solvent.  Range is matsci:Material following the role-based redesign."@en ;
    rdfs:domain matsci:NanocrystalSuperlatticeSample ;
    rdfs:range matsci:Material .

matsci:hasImpurity a owl:ObjectProperty ;
    rdfs:label "has impurity"@en ;
    rdfs:comment
        "Links a superlattice sample to a material that occurs as an impurity in that context."@en ;
    rdfs:domain matsci:NanocrystalSuperlatticeSample ;
    rdfs:range matsci:Impurity .

matsci:hasLuminescentImpurity a owl:ObjectProperty ;
    rdfs:label "has luminescent impurity"@en ;
    rdfs:domain matsci:NanocrystalSuperlatticeSample ;
    rdfs:range matsci:LuminescentImpurity ;
    rdfs:subPropertyOf matsci:hasImpurity .

#################################################################
# Controlled vocabulary individuals
#################################################################

matsci:Absorption a owl:NamedIndividual, matsci:OpticalCharacterizationMethod ;
    rdfs:label "UV-vis absorption"@en ;
    dcterms:alternative "Absorption", "absorption" .

matsci:Ellipsometry a owl:NamedIndividual, matsci:OpticalCharacterizationMethod ;
    rdfs:label "ellipsometry"@en .

matsci:PLE a owl:NamedIndividual, matsci:OpticalCharacterizationMethod ;
    rdfs:label "photoluminescence excitation (PLE)"@en .

matsci:Photoluminescence a owl:NamedIndividual, matsci:OpticalCharacterizationMethod ;
    rdfs:label "photoluminescence (PL)"@en ;
    dcterms:alternative "PL", "Photoluminescence" ;
    rdfs:comment "Photoluminescence is emission of light after photon absorption."@en .

matsci:PolarizationResolvedPL a owl:NamedIndividual, matsci:OpticalCharacterizationMethod ;
    rdfs:label "polarization-resolved PL"@en .

matsci:Raman a owl:NamedIndividual, matsci:OpticalCharacterizationMethod ;
    rdfs:label "Raman spectroscopy"@en .

matsci:Reflectance a owl:NamedIndividual, matsci:OpticalCharacterizationMethod ;
    rdfs:label "reflectance"@en .

matsci:TA a owl:NamedIndividual, matsci:OpticalCharacterizationMethod ;
    rdfs:label "transient absorption (pump-probe)"@en ;
    dcterms:alternative "pump-probe" .

matsci:TRPL a owl:NamedIndividual, matsci:OpticalCharacterizationMethod ;
    rdfs:label "time-resolved PL (TRPL)"@en .

matsci:XRD a owl:NamedIndividual, matsci:StructuralCharacterizationMethod ;
    rdfs:label "X-ray diffraction (XRD)"@en .

matsci:LARP a owl:NamedIndividual, matsci:SynthesisMethod ;
    rdfs:label "ligand-assisted reprecipitation"@en ;
    dcterms:alternative "LARP", "anti-solvent reprecipitation" .

matsci:hot_injection a owl:NamedIndividual, matsci:SynthesisMethod ;
    rdfs:label "hot-injection synthesis"@en ;
    dcterms:alternative "hot injection" .

matsci:mechanochemical a owl:NamedIndividual, matsci:SynthesisMethod ;
    rdfs:label "mechanochemical synthesis"@en ;
    dcterms:alternative "ball-milling" .

matsci:solvothermal a owl:NamedIndividual, matsci:SynthesisMethod ;
    rdfs:label "solvothermal synthesis"@en .

matsci:AnionExchange a owl:NamedIndividual, matsci:ChemicalTransformationType ;
    rdfs:label "anion exchange"@en .

matsci:CationExchange a owl:NamedIndividual, matsci:ChemicalTransformationType ;
    rdfs:label "cation exchange"@en .

matsci:Doping a owl:NamedIndividual, matsci:ChemicalTransformationType ;
    rdfs:label "doping"@en .

matsci:LigandExchange a owl:NamedIndividual, matsci:ChemicalTransformationType ;
    rdfs:label "ligand exchange"@en .

matsci:LED a owl:NamedIndividual, matsci:OptoelectronicApplication ;
