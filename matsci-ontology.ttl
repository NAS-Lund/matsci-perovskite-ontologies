#################################################################
# Condition factor and condition-value individuals
#
# matsci:ConditionFactor / matsci:QualitativeConditionValue classes now
# live in observation-ontology (obs:ConditionFactor / obs:QualitativeConditionValue).
# These concrete controlled-vocabulary individuals stay minted in the
# matsci namespace since they are domain vocabulary choices, not generic
# infrastructure. (The one exception, "time", moved to observation-ontology as
# obs:time, since temporal-ontology -- which must not import matsci --
# needs to reference it directly as a skos:broader target.)
#################################################################

matsci:atmosphere a owl:NamedIndividual, obs:ConditionFactor ;
    rdfs:label "atmosphere"@en .

matsci:humidity a owl:NamedIndividual, obs:ConditionFactor ;
    rdfs:label "humidity"@en .

matsci:temperature a owl:NamedIndividual, obs:ConditionFactor ;
    rdfs:label "temperature"@en .

matsci:air a owl:NamedIndividual, obs:QualitativeConditionValue ;
    rdfs:label "air"@en .

matsci:vacuum a owl:NamedIndividual, obs:QualitativeConditionValue ;
    rdfs:label "vacuum"@en .

matsci:nitrogenAtmosphere a owl:NamedIndividual, obs:QualitativeConditionValue ;
    rdfs:label "nitrogen atmosphere"@en .

#################################################################
# Entity temporal state individuals (matsci-specific)
#
# Domain-specific storage/aging states, moved out of temporal-ontology
# 3.1.0. Siblings of the universal fresh/aged/stored trio defined on
# tempo:EntityTemporalState.
#################################################################

matsci:airAgedEntityState a owl:NamedIndividual, tempo:EntityTemporalState ;
    rdfs:label "air-aged"@en .

matsci:vacuumAgedEntityState a owl:NamedIndividual, tempo:EntityTemporalState ;
    rdfs:label "vacuum-aged"@en .

matsci:plate a owl:NamedIndividual, matsci:ShapeValue ;
    rdfs:label "plate"@en .

matsci:rod a owl:NamedIndividual, matsci:ShapeValue ;
    rdfs:label "rod"@en .

matsci:wire a owl:NamedIndividual, matsci:ShapeValue ;
    rdfs:label "wire"@en .

matsci:facet100 a owl:NamedIndividual, matsci:FacetExposureValue ;
    rdfs:label "{100}"@en .

matsci:facet110 a owl:NamedIndividual, matsci:FacetExposureValue ;
    rdfs:label "{110}"@en .

matsci:facet111 a owl:NamedIndividual, matsci:FacetExposureValue ;
    rdfs:label "{111}"@en .

#################################################################
# Observable property vocabulary
#################################################################

matsci:absorptionCoefficientProperty a owl:NamedIndividual, matsci:ObservableMaterialProperty ;
    rdfs:label "absorption coefficient"@en .

matsci:bandgapProperty a owl:NamedIndividual, matsci:ObservableMaterialProperty ;
    rdfs:label "bandgap"@en ;
    rdfs:comment "The bandgap of a material, treated as an observable property in an observation."@en .

matsci:biexcitonBindingEnergyProperty a owl:NamedIndividual, matsci:ObservableMaterialProperty ;
    rdfs:label "biexciton binding energy"@en .

matsci:bleachCrossSectionProperty a owl:NamedIndividual, matsci:ObservableMaterialProperty ;
    rdfs:label "bleach cross-section"@en .

matsci:excitonBindingEnergyProperty a owl:NamedIndividual, matsci:ObservableMaterialProperty ;
    rdfs:label "exciton binding energy"@en .

matsci:fineStructureSplittingProperty a owl:NamedIndividual, matsci:ObservableMaterialProperty ;
    rdfs:label "fine-structure splitting"@en .

matsci:fwhmProperty a owl:NamedIndividual, matsci:ObservableMaterialProperty ;
    rdfs:label "FWHM"@en .

matsci:gFactorProperty a owl:NamedIndividual, matsci:ObservableMaterialProperty ;
    rdfs:label "exciton g-factor"@en .

matsci:lifetimeProperty a owl:NamedIndividual,
        matsci:ObservableMaterialProperty ;
    rdfs:label "lifetime"@en ;
    dcterms:alternative "PL lifetime", "photoluminescence lifetime" .
matsci:oscillatorStrengthProperty a owl:NamedIndividual, matsci:ObservableMaterialProperty ;
    rdfs:label "oscillator strength"@en .

matsci:plPeakWavelengthProperty a owl:NamedIndividual, matsci:ObservableMaterialProperty ;
    rdfs:label "PL peak wavelength"@en ;
    dcterms:alternative "PL peak energy" .

matsci:polarizationAnisotropyProperty a owl:NamedIndividual, matsci:ObservableMaterialProperty ;
    rdfs:label "polarization anisotropy"@en .

matsci:quantumYieldProperty a owl:NamedIndividual, matsci:ObservableMaterialProperty ;
    rdfs:label "quantum yield"@en .

matsci:refractiveIndexProperty a owl:NamedIndividual, matsci:ObservableMaterialProperty ;
    rdfs:label "refractive index"@en .

matsci:stimulatedEmissionCrossSectionProperty a owl:NamedIndividual, matsci:ObservableMaterialProperty ;
    rdfs:label "stimulated emission cross-section"@en .

matsci:stokesShiftProperty a owl:NamedIndividual, matsci:ObservableMaterialProperty ;
    rdfs:label "Stokes shift"@en .

matsci:urbachEnergyProperty a owl:NamedIndividual, matsci:ObservableMaterialProperty ;
    rdfs:label "Urbach energy"@en .

matsci:dimensionalityProperty a owl:NamedIndividual, matsci:ObservableMorphologyProperty ;
    rdfs:label "dimensionality"@en .

matsci:edgeLengthProperty a owl:NamedIndividual, matsci:ObservableMorphologyProperty ;
    rdfs:label "edge length"@en ;
    rdfs:comment
        "Observable property for edge length.  Corresponds to the matsci:hasEdgeLength shortcut on NanocrystalMorphologyState."@en .

matsci:facetExposureProperty a owl:NamedIndividual, matsci:ObservableMorphologyProperty ;
    rdfs:label "facet exposure"@en .

matsci:packingMotifProperty a owl:NamedIndividual, matsci:ObservableMorphologyProperty ;
    rdfs:label "packing motif"@en .

matsci:shapeProperty a owl:NamedIndividual, matsci:ObservableMorphologyProperty ;
    rdfs:label "shape"@en .

matsci:superlatticeSymmetryProperty a owl:NamedIndividual, matsci:ObservableMorphologyProperty ;
    rdfs:label "superlattice symmetry"@en .

matsci:thicknessProperty a owl:NamedIndividual, matsci:ObservableMorphologyProperty ;
    rdfs:label "thickness"@en ;
    rdfs:comment
        "Observable property for thickness.  Corresponds to the matsci:hasThickness shortcut on NanocrystalMorphologyState."@en .

#################################################################
# Collective optical phenomena
#
# matsci:PhysicalPhenomenon itself now lives in observation-ontology as
# obs:PhysicalPhenomenon.
#################################################################

matsci:CollectiveEmissionPhenomenon a owl:Class ;
    rdfs:label "Collective emission phenomenon"@en ;
    rdfs:comment "A physical phenomenon involving collective light emission from an ensemble of emitters, such as superfluorescence or superradiance."@en ;
    rdfs:subClassOf obs:PhysicalPhenomenon .

matsci:Superfluorescence a owl:Class ;
    rdfs:label "Superfluorescence"@en ;
    dcterms:alternative "SF", "superfluorescent emission" ;
    rdfs:comment "A collective emission phenomenon characterized by delayed, correlated, burst-like emission from an ensemble of excited emitters."@en ;
    rdfs:subClassOf matsci:CollectiveEmissionPhenomenon .

matsci:Superradiance a owl:Class ;
    rdfs:label "Superradiance"@en ;
    dcterms:alternative "SR", "superradiant emission" ;
    rdfs:comment "A collective emission phenomenon characterized by enhanced radiative emission caused by coherent or cooperative coupling between emitters."@en ;
    rdfs:subClassOf matsci:CollectiveEmissionPhenomenon .

matsci:associatedWithPhenomenon a owl:ObjectProperty ;
    rdfs:label "associated with phenomenon"@en ;
    rdfs:comment "Links an observation, time-dependent effect, or observable property to the physical phenomenon it characterizes or affects."@en ;
    rdfs:range obs:PhysicalPhenomenon .

matsci:ObservableCollectiveEmissionProperty a owl:Class ;
    rdfs:label "Observable collective emission property"@en ;
    rdfs:comment "An observable property used to characterize collective emission phenomena such as superfluorescence or superradiance."@en ;
    rdfs:subClassOf matsci:ObservableMaterialProperty .

matsci:superfluorescenceIntensityProperty a owl:NamedIndividual, matsci:ObservableCollectiveEmissionProperty ;
    rdfs:label "superfluorescence intensity"@en ;
    dcterms:alternative "SF intensity" ;
    matsci:associatedWithPhenomenon matsci:Superfluorescence .

matsci:superfluorescenceDelayTimeProperty a owl:NamedIndividual,
        matsci:ObservableCollectiveEmissionProperty ;
    rdfs:label "superfluorescence delay time"@en ;
    dcterms:alternative "SF delay time", "burst delay time" ;
    matsci:associatedWithPhenomenon matsci:Superfluorescence .

matsci:superfluorescenceLifetimeProperty a owl:NamedIndividual,
        matsci:ObservableCollectiveEmissionProperty ;
    rdfs:label "superfluorescence lifetime"@en ;
    dcterms:alternative "SF lifetime" ;
    matsci:associatedWithPhenomenon matsci:Superfluorescence .

matsci:superradianceIntensityProperty a owl:NamedIndividual, matsci:ObservableCollectiveEmissionProperty ;
    rdfs:label "superradiance intensity"@en ;
    dcterms:alternative "SR intensity" ;
    matsci:associatedWithPhenomenon matsci:Superradiance .

matsci:superradianceLifetimeProperty a owl:NamedIndividual,
        matsci:ObservableCollectiveEmissionProperty ;
    rdfs:label "superradiance lifetime"@en ;
    dcterms:alternative "SR lifetime" ;
    matsci:associatedWithPhenomenon matsci:Superradiance .

matsci:AgingInfluenceOnSuperfluorescence a owl:Class ;
    rdfs:label "Aging influence on superfluorescence"@en ;
    rdfs:comment "A time-dependent effect in which sample aging affects superfluorescence-related observable properties, such as intensity, delay time, lifetime, threshold, or emission dynamics."@en .

matsci:AgingInfluenceOnSuperradiance a owl:Class ;
    rdfs:label "Aging influence on superradiance"@en ;
    rdfs:comment "A time-dependent effect in which sample aging affects superradiance-related observable properties, such as intensity, lifetime, emission rate, or cooperative emission behavior."@en .

#################################################################
# Temporal condition factors (matsci-specific)
#
# Domain-specific temporal factors moved out of temporal-ontology 3.0.0.
# They chain up to tempo:duration or obs:time via skos:broader.
#################################################################

matsci:processDuration a owl:NamedIndividual, obs:ConditionFactor ;
    rdfs:label "process duration"@en ;
    rdfs:comment "Duration of a materials-science process."@en ;
    skos:broader tempo:duration .

matsci:synthesisDuration a owl:NamedIndividual, obs:ConditionFactor ;
    rdfs:label "synthesis duration"@en ;
    rdfs:comment "Duration of a synthesis process or synthesis step."@en ;
    skos:broader matsci:processDuration .

matsci:assemblyDuration a owl:NamedIndividual, obs:ConditionFactor ;
    rdfs:label "assembly duration"@en ;
    rdfs:comment "Duration of an assembly or self-assembly process."@en ;
    skos:broader matsci:processDuration .

matsci:pulseDuration a owl:NamedIndividual, obs:ConditionFactor ;
    rdfs:label "pulse duration"@en ;
    rdfs:comment "Temporal width of an excitation, pump, or probe pulse."@en ;
    skos:broader tempo:duration .

#################################################################
# Temporal observable properties (matsci-specific)
#
# Domain-specific temporal observable properties moved out of
# temporal-ontology 3.0.0. Temporal typing against tempo: classes is
# asserted in the section below.
#################################################################

matsci:processDurationProperty a owl:NamedIndividual ;
    rdfs:label "process duration"@en .

matsci:synthesisDurationProperty a owl:NamedIndividual ;
    rdfs:label "synthesis duration"@en .

matsci:assemblyDurationProperty a owl:NamedIndividual ;
    rdfs:label "assembly duration"@en .

matsci:reactionTimeProperty a owl:NamedIndividual ;
    rdfs:label "reaction time"@en .

matsci:solventEvaporationTimeProperty a owl:NamedIndividual ;
    rdfs:label "solvent evaporation time"@en .

matsci:dryingTimeProperty a owl:NamedIndividual ;
    rdfs:label "drying time"@en .

matsci:centrifugationTimeProperty a owl:NamedIndividual ;
    rdfs:label "centrifugation time"@en .

matsci:measurementDelayTimeProperty a owl:NamedIndividual ;
    rdfs:label "measurement delay time"@en .

matsci:pumpProbeDelayTimeProperty a owl:NamedIndividual ;
    rdfs:label "pump-probe delay time"@en ;
    dcterms:alternative "pump-probe delay", "delay time", "Δt" .

matsci:pulseDurationProperty a owl:NamedIndividual ;
    rdfs:label "pulse duration"@en .

matsci:radiativeDurationProperty a owl:NamedIndividual ;
    rdfs:label "radiative duration"@en ;
    dcterms:alternative "radiative time" .

matsci:decayTimeProperty a owl:NamedIndividual ;
    rdfs:label "decay time"@en ;
    dcterms:alternative "decay lifetime", "decay component" .

matsci:relaxationTimeProperty a owl:NamedIndividual ;
    rdfs:label "relaxation time"@en .

matsci:coherenceTimeProperty a owl:NamedIndividual ;
    rdfs:label "coherence time"@en ;
    dcterms:alternative "temporal coherence time" .

matsci:energyTransferTimeProperty a owl:NamedIndividual ;
    rdfs:label "energy transfer time"@en ;
    dcterms:alternative "FRET time", "FRET lifetime" .

matsci:carrierCoolingTimeProperty a owl:NamedIndividual ;
    rdfs:label "carrier cooling time"@en .

#################################################################
# Temporal typing of matsci-native terms
#
# These individuals and classes are minted and primarily typed above, in
# matsci-ontology's own namespace. The triples below add their temporal
# typing/subclassing here, now that matsci-ontology imports
# temporal-ontology (temporal-ontology depends only on observation-ontology, so
# this direction keeps the dependency graph acyclic). Previously (temporal
# 1.0.0 / matsci 1.4.0), this typing lived in temporal-ontology as
# "supplementary assertions" on matsci IRIs, to avoid matsci importing
# temporal; that workaround is no longer needed.
#################################################################

matsci:processDurationProperty a tempo:ObservableProcessTemporalProperty .

matsci:synthesisDurationProperty a tempo:ObservableProcessTemporalProperty .

matsci:assemblyDurationProperty a tempo:ObservableProcessTemporalProperty .

matsci:reactionTimeProperty a tempo:ObservableProcessTemporalProperty .

matsci:solventEvaporationTimeProperty a tempo:ObservableProcessTemporalProperty .

matsci:dryingTimeProperty a tempo:ObservableProcessTemporalProperty .

matsci:centrifugationTimeProperty a tempo:ObservableProcessTemporalProperty .

matsci:measurementDelayTimeProperty a tempo:ObservableTransientTemporalProperty .

matsci:pumpProbeDelayTimeProperty a tempo:ObservableTransientTemporalProperty .

matsci:pulseDurationProperty a tempo:ObservableTransientTemporalProperty .

matsci:radiativeDurationProperty a tempo:ObservableTransientTemporalProperty .

matsci:decayTimeProperty a tempo:ObservableTransientTemporalProperty .

matsci:relaxationTimeProperty a tempo:ObservableTransientTemporalProperty .

matsci:coherenceTimeProperty a tempo:ObservableTransientTemporalProperty .

matsci:energyTransferTimeProperty a tempo:ObservableTransientTemporalProperty .

matsci:carrierCoolingTimeProperty a tempo:ObservableTransientTemporalProperty .

matsci:lifetimeProperty a tempo:ObservableTransientTemporalProperty .

matsci:superfluorescenceDelayTimeProperty a tempo:ObservableTransientTemporalProperty .

matsci:superfluorescenceLifetimeProperty a tempo:ObservableTransientTemporalProperty .

matsci:superradianceLifetimeProperty a tempo:ObservableTransientTemporalProperty .

matsci:AgingInfluenceOnSuperfluorescence rdfs:subClassOf tempo:AgingEffect .

matsci:AgingInfluenceOnSuperradiance rdfs:subClassOf tempo:AgingEffect .
