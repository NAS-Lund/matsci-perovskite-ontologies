matsci:Laser a owl:NamedIndividual, matsci:OptoelectronicApplication ;
    rdfs:label "laser"@en .

matsci:SolarCell a owl:NamedIndividual, matsci:OptoelectronicApplication ;
    rdfs:label "solar cell"@en .

matsci:Memristor a owl:NamedIndividual, matsci:Application ;
    rdfs:label "memristor"@en .

matsci:acetone a owl:NamedIndividual, matsci:Material ;
    rdfs:label "acetone"@en ;
    dcterms:alternative "2-propanone", "Dimethyl ketone", "propanone" .

matsci:isopropanol a owl:NamedIndividual, matsci:Material ;
    rdfs:label "isopropanol"@en ;
    dcterms:alternative "IPA" .

matsci:acetonitrile a owl:NamedIndividual, matsci:Material ;
    rdfs:label "acetonitrile"@en ;
    dcterms:alternative "ACN" .

matsci:dmf a owl:NamedIndividual, matsci:Material ;
    rdfs:label "DMF"@en ;
    dcterms:alternative "Dimethylformamide" .

matsci:dmso a owl:NamedIndividual, matsci:Material ;
    rdfs:label "DMSO"@en ;
    dcterms:alternative "Dimethyl sulfoxide" .

matsci:hexane a owl:NamedIndividual, matsci:Material ;
    rdfs:label "hexane"@en ;
    dcterms:alternative "n-hexane" .

matsci:octadecene a owl:NamedIndividual, matsci:Material ;
    rdfs:label "octadecene"@en .

matsci:toluene a owl:NamedIndividual, matsci:Material ;
    rdfs:label "toluene"@en ;
    dcterms:alternative "PhCH3" .

matsci:hexylamine a owl:NamedIndividual, matsci:Material ;
    rdfs:label "hexylamine"@en .

matsci:octylamine a owl:NamedIndividual, matsci:Material ;
    rdfs:label "octylamine"@en ;
    dcterms:alternative "1-Aminooctane", "N-OCTYLAMINE", "octan-1-amine" .

matsci:oleicAcid a owl:NamedIndividual, matsci:Material ;
    rdfs:label "oleic acid"@en ;
    dcterms:alternative "OA" .

matsci:oleylamine a owl:NamedIndividual, matsci:Material ;
    rdfs:label "oleylamine"@en ;
    dcterms:alternative "OLA" .

matsci:oleylammoniumBromide a owl:NamedIndividual, matsci:Material ;
    rdfs:label "oleylammonium bromide"@en ;
