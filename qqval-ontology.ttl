@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix qqval:   <https://growgraph.dev/ontologies/qqval-ontology#> .
@prefix qudt:    <http://qudt.org/schema/qudt/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix om:      <http://www.ontology-of-units-of-measure.org/resource/om-2/> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# Ontology header
#################################################################

<https://growgraph.dev/ontologies/qqval-ontology> a owl:Ontology ;
    rdfs:label "qqval"@en ;
    dcterms:creator "growgraph.dev" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment
        """Reusable ontology for expressing quantitative values whose
        reported numeric component carries an epistemic qualifier: it may
        be approximate, a range, a one-sided bound, or a value given with
        an explicit uncertainty.

        1.1.0: fixed a namespace/IRI mismatch. This ontology's own IRI and
        namespace hash previously read '.../qqval' and '.../qqval#', while
        every consumer (matsci-ontology, temporal-ontology) already
        imported and prefixed it as '.../qqval-ontology' and
        '.../qqval-ontology#'. That meant owl:imports and qqval: terms in
        consuming ontologies resolved to an IRI this file never actually
        declared. Standardized on '-ontology' to match the consumers and
        the naming convention used by matsci-ontology/temporal-ontology/
        core-ontology, rather than editing every consumer.

        1.1.1: cosmetic consistency pass -- aligned the @prefix block,
        reordered the ontology header (versionIRI before owl:imports, to
        match core-ontology/temporal-ontology/matsci-ontology), and
        shortened rdfs:label to a bare name like the other ontologies in
        this collection."""@en ;
    owl:versionIRI <https://growgraph.dev/ontologies/qqval-ontology/1.1.1> ;
    owl:imports
        <http://qudt.org/2.1/schema/facade/qudt> ,
        <http://qudt.org/2.1/vocab/unit> ;
    owl:versionInfo "1.1.1" ;
    rdfs:seeAlso
        <http://www.ontology-of-units-of-measure.org/resource/om-2/> .


#################################################################
# ApproximationQualifier — class
#################################################################

qqval:ApproximationQualifier a owl:Class ;
    rdfs:label "Approximation qualifier"@en ;
    rdfs:comment
        """A controlled-vocabulary individual that encodes the epistemic
        status of a reported numeric value: whether it is exact, approximate,
        a one-sided bound, a range, or carries an explicit uncertainty.
        Instances of this class are the named individuals defined below."""@en ;
    skos:altLabel
        "measurement qualifier"@en ,
        "numeric qualifier"@en ,
        "value qualifier"@en ,
        "epistemic qualifier"@en ;
    rdfs:isDefinedBy <https://growgraph.dev/ontologies/qqval-ontology> .


#################################################################
# ApproximationQualifier — named individuals (controlled vocabulary)
#
# SKOS hierarchy (conceptual, not subclassing):
#   Approximate (broad)
#     ├─ Range             (both bounds known)
#     ├─ AtLeast           (lower bound only)
#     ├─ AtMost            (upper bound only)
#     └─ WithUncertainty   (centre ± symmetric delta)
#   Exact                  (conceptually independent — no approximation)
#################################################################

qqval:Exact a owl:NamedIndividual , qqval:ApproximationQualifier ;
    rdfs:label "exact"@en ;
    rdfs:comment
        """The reported value is considered exact or nominal within the
        precision of the source.  No approximation qualifier is applied.
        Useful in extraction pipelines that need an explicit marker for
        values that are not annotated with ~, ±, ranges, or bounds."""@en ;
    skos:altLabel
        "nominal"@en , "precise"@en , "exact value"@en ,
        "nominal value"@en , "definite"@en ;
    rdfs:isDefinedBy <https://growgraph.dev/ontologies/qqval-ontology> .

qqval:Approximate a owl:NamedIndividual , qqval:ApproximationQualifier ;
    rdfs:label "approximately"@en ;
    rdfs:comment
        """The reported value is a central estimate, not exact.
        Expressed in source text as ∼, ~, ≈, ca., about, roughly,
        or nominally."""@en ;
    skos:altLabel
        "∼"@en , "~"@en , "≈"@en ,
        "ca."@en , "about"@en , "roughly"@en ,
        "nominally"@en , "around"@en , "near"@en ,
        "approximate value"@en , "order of magnitude"@en ;
    skos:narrower qqval:Range , qqval:AtLeast , qqval:AtMost , qqval:WithUncertainty ;
    rdfs:isDefinedBy <https://growgraph.dev/ontologies/qqval-ontology> .

qqval:Range a owl:NamedIndividual , qqval:ApproximationQualifier ;
    rdfs:label "range"@en ;
    rdfs:comment
        """The value is an interval with explicit lower and upper bounds.
        Expressed in source text as X–Y, X to Y, between X and Y,
        from X to Y, or X−Y (en-dash or hyphen).
        Requires both qqval:numericLowerBound and qqval:numericUpperBound."""@en ;
    skos:altLabel
        "interval"@en , "X–Y"@en , "from X to Y"@en ,
        "between X and Y"@en , "X to Y"@en ,
        "lower to upper"@en , "bounded interval"@en ,
        "numeric range"@en , "value range"@en ,
        "range of values"@en ;
    skos:broader qqval:Approximate ;
    rdfs:isDefinedBy <https://growgraph.dev/ontologies/qqval-ontology> .

qqval:AtMost a owl:NamedIndividual , qqval:ApproximationQualifier ;
    rdfs:label "at most"@en ;
    rdfs:comment
        """Only an upper bound is known or reported.
        Expressed in source text as <, ≤, up to, no more than, at most,
        below, less than, not exceeding, maximum.
        Requires qqval:numericUpperBound; qqval:numericLowerBound must be absent."""@en ;
    skos:altLabel
        "<"@en , "≤"@en ,
        "up to"@en , "no more than"@en , "below"@en ,
        "less than"@en , "not exceeding"@en ,
        "maximum"@en , "upper bound only"@en ,
        "smaller than"@en ;
    skos:broader qqval:Approximate ;
    rdfs:isDefinedBy <https://growgraph.dev/ontologies/qqval-ontology> .

qqval:AtLeast a owl:NamedIndividual , qqval:ApproximationQualifier ;
    rdfs:label "at least"@en ;
    rdfs:comment
        """Only a lower bound is known or reported.
        Expressed in source text as >, ≥, at least, more than,
        exceeding, above, greater than, minimum, or more.
        Requires qqval:numericLowerBound; qqval:numericUpperBound must be absent."""@en ;
    skos:altLabel
        ">"@en , "≥"@en ,
        "at least"@en , "more than"@en , "exceeding"@en ,
        "above"@en , "greater than"@en ,
        "minimum"@en , "lower bound only"@en ,
        "larger than"@en ;
    skos:broader qqval:Approximate ;
    rdfs:isDefinedBy <https://growgraph.dev/ontologies/qqval-ontology> .

qqval:WithUncertainty a owl:NamedIndividual , qqval:ApproximationQualifier ;
    rdfs:label "with uncertainty"@en ;
    rdfs:comment
        """The nominal value is given together with an explicit absolute
        uncertainty.  Expressed in source text as X ± Y, X +/- Y,
        X ± δX, or X with standard deviation Y.
        Requires qqval:numericUncertainty; bound properties must be absent."""@en ;
    skos:altLabel
        "±"@en , "+/-"@en , "plus or minus"@en ,
        "X ± Y"@en , "standard deviation"@en ,
        "error bar"@en , "measurement uncertainty"@en ,
        "absolute uncertainty"@en , "uncertainty"@en ,
        "experimental error"@en , "margin of error"@en ;
    skos:broader qqval:Approximate ;
    rdfs:isDefinedBy <https://growgraph.dev/ontologies/qqval-ontology> .

# All qualifier individuals are mutually distinct
[] a owl:AllDifferent ;
    owl:distinctMembers (
        qqval:Exact
        qqval:Approximate
        qqval:Range
        qqval:AtMost
        qqval:AtLeast
        qqval:WithUncertainty
    ) .


#################################################################
# ApproximateQuantityValue — class
#
# Pattern: compact flat representation of a qualified scalar or
# range, all values sharing one unit attached to this node.
#################################################################

qqval:ApproximateQuantityValue a owl:Class ;
    rdfs:label "Approximate quantity value"@en ;
    rdfs:comment
        """A qudt:QuantityValue whose reported numeric component carries an
        epistemic qualifier: it may be exact, approximate, a range, a
        one-sided bound, or a value ± uncertainty.

        All numeric components are plain xsd:decimal literals sharing the
        unit declared via qudt:unit on this node:
          • qudt:numericValue          — central / nominal value
          • qqval:numericLowerBound     — inclusive lower bound  (Range, AtLeast)
          • qqval:numericUpperBound     — inclusive upper bound  (Range, AtMost)
          • qqval:numericUncertainty    — absolute ± uncertainty (WithUncertainty)
          • qqval:numericRelativeUncertainty — relative ± uncertainty in % (WithUncertainty)

        The epistemic status is declared via qqval:approximationQualifier
        pointing to one of the named individuals above.  Multiple qualifiers
        may be combined (e.g. Range + Approximate for ~X–Y).

        Usage guide by qualifier:
          Exact           → qudt:numericValue only
          Approximate     → qudt:numericValue only
          Range           → numericLowerBound + numericUpperBound (no numericValue required)
          AtLeast         → numericLowerBound only
          AtMost          → numericUpperBound only
          WithUncertainty → qudt:numericValue + numericUncertainty or numericRelativeUncertainty

        Contrast with qqval:QuantityRange, which models bounds as *object*
        properties to separate qudt:QuantityValue nodes and is appropriate
        when bounds have independent units or independent provenance."""@en ;
    rdfs:subClassOf qudt:QuantityValue ;
    skos:altLabel
        "bounded quantity value"@en ,
        "measured quantity with uncertainty"@en ,
        "approximate measurement"@en ,
        "approximate value"@en ,
        "value with error bar"@en ,
        "value with qualifier"@en ,
        "inexact measurement"@en ;
    rdfs:seeAlso
        om:Measure ,
        qudt:QuantityValue ,
        qqval:QuantityRange ;
    rdfs:isDefinedBy <https://growgraph.dev/ontologies/qqval-ontology> ;
    # At least one approximation qualifier is required
    rdfs:subClassOf
        [ a owl:Restriction ;
            owl:onProperty qqval:approximationQualifier ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger
        ] ;
    # A unit is required
    rdfs:subClassOf
        [ a owl:Restriction ;
            owl:onProperty qudt:unit ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger
        ] ;
    # At most one lower bound
    rdfs:subClassOf
        [ a owl:Restriction ;
            owl:onProperty qqval:numericLowerBound ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger
        ] ;
    # At most one upper bound
    rdfs:subClassOf
        [ a owl:Restriction ;
            owl:onProperty qqval:numericUpperBound ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger
        ] ;
    # At most one absolute uncertainty
    rdfs:subClassOf
        [ a owl:Restriction ;
            owl:onProperty qqval:numericUncertainty ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger
        ] ;
    # At most one relative uncertainty
    rdfs:subClassOf
        [ a owl:Restriction ;
            owl:onProperty qqval:numericRelativeUncertainty ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger
        ] .


#################################################################
# QuantityRange — class
#
# Pattern: bounds represented as independent qudt:QuantityValue
# object nodes (may carry their own units and provenance).
#################################################################

qqval:QuantityRange a owl:Class ;
    rdfs:label "Quantity range"@en ;
    rdfs:comment
        """A quantitative interval defined by lower and/or upper bound nodes,
        each being an independent qudt:QuantityValue.  Use this pattern
        when bounds may carry different units, independent provenance, or
        individual observation metadata.

        At least one bound (lower or upper) must be present.

        Contrast with qqval:ApproximateQuantityValue (using qqval:Range
        qualifier), which stores bounds as plain decimals on a single node
        sharing one unit — preferable for compact, unit-homogeneous ranges."""@en ;
    rdfs:seeAlso qqval:ApproximateQuantityValue ;
    rdfs:isDefinedBy <https://growgraph.dev/ontologies/qqval-ontology> ;
    # At most one lower bound node
    rdfs:subClassOf
        [ a owl:Restriction ;
            owl:onProperty qqval:hasLowerBound ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass qudt:QuantityValue
        ] ;
    # At most one upper bound node
    rdfs:subClassOf
        [ a owl:Restriction ;
            owl:onProperty qqval:hasUpperBound ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass qudt:QuantityValue
        ] ;
    # At least one bound must be present (lower OR upper)
    rdfs:subClassOf
        [ a owl:Class ;
            owl:unionOf (
                [ a owl:Restriction ;
                    owl:onProperty qqval:hasLowerBound ;
                    owl:someValuesFrom qudt:QuantityValue ]
                [ a owl:Restriction ;
                    owl:onProperty qqval:hasUpperBound ;
                    owl:someValuesFrom qudt:QuantityValue ]
            )
        ] .

# The two range patterns are intentionally distinct: do not conflate them
qqval:ApproximateQuantityValue owl:disjointWith qqval:QuantityRange .


#################################################################
# Object properties
#################################################################

qqval:approximationQualifier a owl:ObjectProperty ;
    rdfs:label "approximation qualifier"@en ;
    rdfs:comment
        """Links an ApproximateQuantityValue to one or more
        ApproximationQualifier named individuals that encode the epistemic
        status of the reported number."""@en ;
    skos:altLabel
        "epistemic qualifier"@en ,
        "numeric qualifier"@en ,
        "value qualifier"@en ,
        "measurement qualifier"@en ,
        "bound type"@en ,
        "approximation type"@en ;
    rdfs:domain qqval:ApproximateQuantityValue ;
    rdfs:range  qqval:ApproximationQualifier ;
    rdfs:isDefinedBy <https://growgraph.dev/ontologies/qqval-ontology> .

qqval:hasLowerBound a owl:ObjectProperty ;
    rdfs:label "has lower bound"@en ;
    rdfs:comment
        """Links a QuantityRange to a qudt:QuantityValue representing the
        inclusive lower bound.  Prefer qqval:numericLowerBound on
        ApproximateQuantityValue when all bounds share one unit."""@en ;
    rdfs:domain qqval:QuantityRange ;
    rdfs:range  qudt:QuantityValue ;
    rdfs:seeAlso qqval:numericLowerBound ;
    rdfs:isDefinedBy <https://growgraph.dev/ontologies/qqval-ontology> .

qqval:hasUpperBound a owl:ObjectProperty ;
    rdfs:label "has upper bound"@en ;
    rdfs:comment
        """Links a QuantityRange to a qudt:QuantityValue representing the
        inclusive upper bound.  Prefer qqval:numericUpperBound on
        ApproximateQuantityValue when all bounds share one unit."""@en ;
    rdfs:domain qqval:QuantityRange ;
    rdfs:range  qudt:QuantityValue ;
    rdfs:seeAlso qqval:numericUpperBound ;
    rdfs:isDefinedBy <https://growgraph.dev/ontologies/qqval-ontology> .


#################################################################
# Datatype properties
#################################################################

qqval:numericLowerBound a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "numeric lower bound"@en ;
    rdfs:comment
        """The inclusive lower bound of a range or AtLeast measurement,
        as a plain decimal sharing the unit of the parent
        ApproximateQuantityValue node.  Use together with
        qqval:numericUpperBound to express an X–Y range, or alone
        with qualifier qqval:AtLeast to express "> X".
        Declared owl:FunctionalProperty: each node carries at most one."""@en ;
    skos:altLabel
        "lower bound"@en ,
        "minimum value"@en ,
        "range minimum"@en ,
        "lower limit"@en ,
        "from value"@en ,
        "range start"@en ;
    rdfs:domain qqval:ApproximateQuantityValue ;
    rdfs:range  xsd:decimal ;
    rdfs:seeAlso qqval:hasLowerBound ;
    rdfs:isDefinedBy <https://growgraph.dev/ontologies/qqval-ontology> .

qqval:numericUpperBound a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "numeric upper bound"@en ;
    rdfs:comment
        """The inclusive upper bound of a range or AtMost measurement,
        as a plain decimal sharing the unit of the parent
        ApproximateQuantityValue node.  Use together with
        qqval:numericLowerBound to express an X–Y range, or alone
        with qualifier qqval:AtMost to express "< X".
        Declared owl:FunctionalProperty: each node carries at most one."""@en ;
    skos:altLabel
        "upper bound"@en ,
        "maximum value"@en ,
        "range maximum"@en ,
        "upper limit"@en ,
        "to value"@en ,
        "range end"@en ;
    rdfs:domain qqval:ApproximateQuantityValue ;
    rdfs:range  xsd:decimal ;
    rdfs:seeAlso qqval:hasUpperBound ;
    rdfs:isDefinedBy <https://growgraph.dev/ontologies/qqval-ontology> .

qqval:numericUncertainty a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "numeric uncertainty"@en ;
    rdfs:comment
        """The absolute symmetric uncertainty (± value) of a measurement,
        as a plain decimal sharing the unit of the parent
        ApproximateQuantityValue node.  Corresponds to the ± notation
        (e.g. 8.5 ± 0.5 nm → qudt:numericValue 8.5, numericUncertainty 0.5).
        Use with qualifier qqval:WithUncertainty.
        Declared owl:FunctionalProperty: each node carries at most one.
        See also qqval:numericRelativeUncertainty for percentage uncertainty."""@en ;
    skos:altLabel
        "absolute uncertainty"@en ,
        "± value"@en ,
        "plus or minus"@en ,
        "standard deviation"@en ,
        "error bar"@en ,
        "measurement error"@en ,
        "experimental uncertainty"@en ,
        "standard error"@en ,
        "confidence interval half-width"@en ;
    rdfs:domain qqval:ApproximateQuantityValue ;
    rdfs:range  xsd:decimal ;
    rdfs:seeAlso om:hasUncertainty ;
    rdfs:isDefinedBy <https://growgraph.dev/ontologies/qqval-ontology> .

qqval:numericRelativeUncertainty a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:label "numeric relative uncertainty"@en ;
    rdfs:comment
        """The relative (percentage) uncertainty of a measurement,
        expressed as a plain decimal in percent (e.g. 5.0 means 5 %).
        Use when the source reports uncertainty as a fraction or percentage
        of the nominal value (e.g. "8.5 nm ± 6 %" → numericRelativeUncertainty 6.0).
        Use with qualifier qqval:WithUncertainty.
        Exactly one of numericUncertainty or numericRelativeUncertainty
        should be present when WithUncertainty is asserted.
        Declared owl:FunctionalProperty: each node carries at most one."""@en ;
    skos:altLabel
        "relative uncertainty"@en ,
        "percentage uncertainty"@en ,
        "percent error"@en ,
        "relative error"@en ,
        "coefficient of variation"@en ,
        "RSD"@en ,
        "relative standard deviation"@en ;
    rdfs:domain qqval:ApproximateQuantityValue ;
    rdfs:range  xsd:decimal ;
    rdfs:seeAlso qqval:numericUncertainty ;
    rdfs:isDefinedBy <https://growgraph.dev/ontologies/qqval-ontology> .
