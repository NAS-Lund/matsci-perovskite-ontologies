@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix obs:     <https://growgraph.dev/ontologies/observation-ontology#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix pergres: <https://growgraph.dev/ontologies/pergres-ontology#> .
@prefix qqval:   <https://growgraph.dev/ontologies/qqval-ontology#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix tempo:   <https://growgraph.dev/ontologies/temporal-ontology#> .

#################################################################
# Shapes graph header
#
# Closed-world validation companion to pergres-ontology. Enforces the
# cross-module qqval-qualification policy that observation-shapes and
# temporal-shapes deliberately leave open.
#################################################################

<https://growgraph.dev/ontologies/pergres-shapes> a owl:Ontology ;
    rdfs:label "pergres shapes"@en ;
    dcterms:creator "growgraph.dev" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment
        """SHACL shapes mirroring pergres-ontology's qqval-qualification
        axioms: QuantitativeObservation results must be
        qqval:QualifiedQuantityValue, and TimeQuantityValue is treated as
        qqval-qualified. Aligns with pergres-ontology >= 1.0.0."""@en ;
    owl:versionIRI <https://growgraph.dev/ontologies/pergres-shapes/1.0.0> ;
    owl:versionInfo "1.0.0" .

#################################################################
# QuantitativeObservation — result must be qqval-qualified
#################################################################

pergres:QuantitativeObservationShape a sh:NodeShape ;
    sh:targetClass obs:QuantitativeObservation ;
    rdfs:comment
        """Tightens observation-shapes' qudt:QuantityValue check to
        qqval:QualifiedQuantityValue. Load together with observation-shapes
        and qqval-shapes."""@en ;
    sh:property
        [ sh:path obs:hasQuantityResult ;
            sh:minCount 1 ;
            sh:class qqval:QualifiedQuantityValue ;
            sh:message "Under pergres policy, QuantitativeObservation requires at least one obs:hasQuantityResult whose value is a qqval:QualifiedQuantityValue (use qqval:Exact when the source value is exact)."@en
        ] .

#################################################################
# TimeQuantityValue — must satisfy QualifiedQuantityValue shape
#################################################################

pergres:TimeQuantityValueShape a sh:NodeShape ;
    sh:targetClass tempo:TimeQuantityValue ;
    rdfs:comment
        """Mirrors pergres-ontology's axiom that tempo:TimeQuantityValue
        is a subclass of qqval:QualifiedQuantityValue. Structural checks
        for epistemicQualifier / unit / numeric form come from
        qqval:QualifiedQuantityValueShape via subclass targeting when
        RDFS inference is enabled; this shape asserts the class membership
        expectation for closed-world validation without inference."""@en ;
    sh:class qqval:QualifiedQuantityValue ;
    sh:message "Under pergres policy, tempo:TimeQuantityValue must also be typed qqval:QualifiedQuantityValue."@en .
