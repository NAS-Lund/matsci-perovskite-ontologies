@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix qqval:   <https://growgraph.dev/ontologies/qqval-ontology#> .
@prefix qudt:    <http://qudt.org/schema/qudt/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# Shapes graph header
#
# Closed-world validation companion to qqval-ontology. OWL restrictions
# are open-world; these SHACL shapes reject non-conforming data outright.
#################################################################

<https://growgraph.dev/ontologies/qqval-shapes> a owl:Ontology ;
    rdfs:label "qqval shapes"@en ;
    dcterms:creator "growgraph.dev" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment
        """SHACL shapes mirroring the OWL cardinality restrictions on
        qqval:QualifiedQuantityValue and qqval:QuantityRange, plus
        property-presence rules for numeric form and uncertainty
        mutual exclusion. Aligns with qqval-ontology >= 2.0.0."""@en ;
    owl:versionIRI <https://growgraph.dev/ontologies/qqval-shapes/2.0.0> ;
    owl:versionInfo "2.0.0" .

#################################################################
# QualifiedQuantityValue — structural shape
#################################################################

qqval:QualifiedQuantityValueShape a sh:NodeShape ;
    sh:targetClass qqval:QualifiedQuantityValue ;
    sh:property
        [ sh:path qqval:epistemicQualifier ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
            sh:class qqval:EpistemicQualifier ;
            sh:message "QualifiedQuantityValue requires exactly one qqval:epistemicQualifier (Exact or Approximate)."@en
        ] ,
        [ sh:path qudt:unit ;
            sh:minCount 1 ;
            sh:message "QualifiedQuantityValue requires qudt:unit."@en
        ] ,
        [ sh:path qudt:numericValue ;
            sh:maxCount 1 ;
            sh:datatype xsd:decimal ;
            sh:message "qudt:numericValue must be a single xsd:decimal."@en
        ] ,
        [ sh:path qqval:numericLowerBound ;
            sh:maxCount 1 ;
            sh:datatype xsd:decimal ;
            sh:message "qqval:numericLowerBound must be a single xsd:decimal."@en
        ] ,
        [ sh:path qqval:numericUpperBound ;
            sh:maxCount 1 ;
            sh:datatype xsd:decimal ;
            sh:message "qqval:numericUpperBound must be a single xsd:decimal."@en
        ] ,
        [ sh:path qqval:lowerBoundInclusive ;
            sh:maxCount 1 ;
            sh:datatype xsd:boolean ;
            sh:message "qqval:lowerBoundInclusive must be a single xsd:boolean."@en
        ] ,
        [ sh:path qqval:upperBoundInclusive ;
            sh:maxCount 1 ;
            sh:datatype xsd:boolean ;
            sh:message "qqval:upperBoundInclusive must be a single xsd:boolean."@en
        ] ,
        [ sh:path qqval:numericUncertainty ;
            sh:maxCount 1 ;
            sh:datatype xsd:decimal ;
            sh:message "qqval:numericUncertainty must be a single xsd:decimal."@en
        ] ,
        [ sh:path qqval:numericRelativeUncertainty ;
            sh:maxCount 1 ;
            sh:datatype xsd:decimal ;
            sh:message "qqval:numericRelativeUncertainty must be a single xsd:decimal."@en
        ] ,
        [ sh:path qqval:confidenceLevel ;
            sh:maxCount 1 ;
            sh:datatype xsd:decimal ;
            sh:message "qqval:confidenceLevel must be a single xsd:decimal, in percent."@en
        ] ,
        [ sh:path qqval:distributionAssumption ;
            sh:maxCount 1 ;
            sh:class qqval:DistributionAssumption ;
            sh:message "qqval:distributionAssumption must be a single qqval:DistributionAssumption individual."@en
        ] ;
    # Representation-pattern convention: not also a QuantityRange
    sh:not [ sh:class qqval:QuantityRange ] ;
    sh:sparql
        [ a sh:SPARQLConstraint ;
            rdfs:comment "At least one of numericValue / numericLowerBound / numericUpperBound must be present."@en ;
            sh:message "QualifiedQuantityValue requires at least one of qudt:numericValue, qqval:numericLowerBound, or qqval:numericUpperBound."@en ;
            sh:select
                """
                PREFIX qqval: <https://growgraph.dev/ontologies/qqval-ontology#>
                PREFIX qudt: <http://qudt.org/schema/qudt/>
                SELECT $this
                WHERE {
                    FILTER ( NOT EXISTS { $this qudt:numericValue ?v }
                             && NOT EXISTS { $this qqval:numericLowerBound ?lb }
                             && NOT EXISTS { $this qqval:numericUpperBound ?ub } )
                }
                """ ;
        ] ,
        [ a sh:SPARQLConstraint ;
            rdfs:comment "Bound properties and uncertainty properties are mutually exclusive."@en ;
            sh:message "QualifiedQuantityValue must not combine bound properties (numericLowerBound/numericUpperBound) with uncertainty properties (numericUncertainty/numericRelativeUncertainty)."@en ;
            sh:select
                """
                PREFIX qqval: <https://growgraph.dev/ontologies/qqval-ontology#>
                SELECT $this
                WHERE {
                    FILTER (
                        ( EXISTS { $this qqval:numericLowerBound ?lb }
                          || EXISTS { $this qqval:numericUpperBound ?ub } )
                        &&
                        ( EXISTS { $this qqval:numericUncertainty ?u }
                          || EXISTS { $this qqval:numericRelativeUncertainty ?r } )
                    )
                }
                """ ;
        ] ,
        [ a sh:SPARQLConstraint ;
            rdfs:comment "At most one of absolute / relative uncertainty."@en ;
            sh:message "QualifiedQuantityValue must not carry both qqval:numericUncertainty and qqval:numericRelativeUncertainty."@en ;
            sh:select
                """
                PREFIX qqval: <https://growgraph.dev/ontologies/qqval-ontology#>
                SELECT $this
                WHERE {
                    $this qqval:numericUncertainty ?u .
                    $this qqval:numericRelativeUncertainty ?r .
                }
                """ ;
        ] ,
        [ a sh:SPARQLConstraint ;
            rdfs:comment "Uncertainty requires a nominal numericValue."@en ;
            sh:message "Uncertainty (numericUncertainty or numericRelativeUncertainty) requires qudt:numericValue."@en ;
            sh:select
                """
                PREFIX qqval: <https://growgraph.dev/ontologies/qqval-ontology#>
                PREFIX qudt: <http://qudt.org/schema/qudt/>
                SELECT $this
                WHERE {
                    FILTER (
                        ( EXISTS { $this qqval:numericUncertainty ?u }
                          || EXISTS { $this qqval:numericRelativeUncertainty ?r } )
                        && NOT EXISTS { $this qudt:numericValue ?v }
                    )
                }
                """ ;
        ] .

#################################################################
# QuantityRange — structural shape
#################################################################

qqval:QuantityRangeShape a sh:NodeShape ;
    sh:targetClass qqval:QuantityRange ;
    sh:property
        [ sh:path qqval:hasLowerBound ;
            sh:maxCount 1 ;
            sh:class qudt:QuantityValue ;
            sh:message "QuantityRange allows at most one qqval:hasLowerBound."@en
        ] ,
        [ sh:path qqval:hasUpperBound ;
            sh:maxCount 1 ;
            sh:class qudt:QuantityValue ;
            sh:message "QuantityRange allows at most one qqval:hasUpperBound."@en
        ] ;
    sh:not [ sh:class qqval:QualifiedQuantityValue ] ;
    sh:sparql
        [ a sh:SPARQLConstraint ;
            rdfs:comment "At least one of hasLowerBound / hasUpperBound must be present."@en ;
            sh:message "QuantityRange requires at least one of qqval:hasLowerBound or qqval:hasUpperBound."@en ;
            sh:select
                """
                PREFIX qqval: <https://growgraph.dev/ontologies/qqval-ontology#>
                SELECT $this
                WHERE {
                    FILTER ( NOT EXISTS { $this qqval:hasLowerBound ?lb }
                             && NOT EXISTS { $this qqval:hasUpperBound ?ub } )
                }
                """ ;
        ] .
