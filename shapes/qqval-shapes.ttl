@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix qqval:   <https://growgraph.dev/ontologies/qqval-ontology#> .
@prefix qudt:    <http://qudt.org/schema/qudt/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# Shapes graph header
#
# Closed-world validation companion to qqval-ontology. OWL restrictions
# in qqval-ontology.ttl are open-world: a reasoner will not flag missing
# data as invalid, only as "not yet known". These SHACL shapes mirror
# the same cardinality/qualifier rules but reject non-conforming data
# outright -- the intended use is validating LLM-extracted graphs before
# they are persisted, not ontological reasoning.
#
# Apply against the data graph together with qqval-ontology's own
# vocabulary (qqval:, qudt:) in scope. Written for SHACL Core plus
# SHACL-SPARQL (sh:sparql) for the qualifier-conditional rules that
# SHACL Core's declarative shapes cannot express.
#################################################################

<https://growgraph.dev/ontologies/qqval-shapes> a owl:Ontology ;
    rdfs:label "qqval shapes"@en ;
    dcterms:creator "growgraph.dev" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment
        """SHACL shapes mirroring the OWL cardinality/qualifier restrictions
        declared on qqval:ApproximateQuantityValue and qqval:QuantityRange
        in qqval-ontology (>= 1.2.0). See that ontology's rdfs:comment for
        the modeling rationale.

        1.0.0: initial version, covering ApproximateQuantityValue's
        structural cardinalities plus the per-qualifier requirements
        (Range needs both bounds, AtLeast/AtMost need exactly one bound,
        WithUncertainty needs a nominal value and an uncertainty, bound
        properties are mutually exclusive with WithUncertainty), and
        QuantityRange's "at least one bound node" rule."""@en ;
    owl:versionIRI <https://growgraph.dev/ontologies/qqval-shapes/1.0.0> ;
    owl:versionInfo "1.0.0" .

#################################################################
# ApproximateQuantityValue — structural shape
#################################################################

qqval:ApproximateQuantityValueShape a sh:NodeShape ;
    sh:targetClass qqval:ApproximateQuantityValue ;
    sh:property
        [ sh:path qqval:approximationQualifier ;
            sh:minCount 1 ;
            sh:class qqval:ApproximationQualifier ;
            sh:message "ApproximateQuantityValue requires at least one qqval:approximationQualifier."@en
        ] ,
        [ sh:path qudt:unit ;
            sh:minCount 1 ;
            sh:message "ApproximateQuantityValue requires qudt:unit."@en
        ] ,
        [ sh:path qudt:numericValue ;
            sh:maxCount 1 ;
            sh:datatype xsd:decimal ;
            sh:message "qudt:numericValue must be a single xsd:decimal."@en
        ] ,
        [ sh:path qqval:numericLowerBound ;
            sh:maxCount 1 ;
            sh:datatype xsd:decimal ;
            sh:message "qqval:numericLowerBound must be a single xsd:decimal."@en
        ] ,
        [ sh:path qqval:numericUpperBound ;
            sh:maxCount 1 ;
            sh:datatype xsd:decimal ;
            sh:message "qqval:numericUpperBound must be a single xsd:decimal."@en
        ] ,
        [ sh:path qqval:numericUncertainty ;
            sh:maxCount 1 ;
            sh:datatype xsd:decimal ;
            sh:message "qqval:numericUncertainty must be a single xsd:decimal."@en
        ] ,
        [ sh:path qqval:numericRelativeUncertainty ;
            sh:maxCount 1 ;
            sh:datatype xsd:decimal ;
            sh:message "qqval:numericRelativeUncertainty must be a single xsd:decimal."@en
        ] ,
        [ sh:path qqval:confidenceLevel ;
            sh:maxCount 1 ;
            sh:datatype xsd:decimal ;
            sh:message "qqval:confidenceLevel must be a single xsd:decimal, in percent."@en
        ] ,
        [ sh:path qqval:distributionAssumption ;
            sh:maxCount 1 ;
            sh:class qqval:DistributionAssumption ;
            sh:message "qqval:distributionAssumption must be a single qqval:DistributionAssumption individual."@en
        ] ;
    # Bound and uncertainty properties are mutually exclusive per-qualifier
    # requirements below; disjointness with QuantityRange mirrors the OWL
    # owl:disjointWith axiom in a closed-world-checkable form.
    sh:not [ sh:class qqval:QuantityRange ] ;
    sh:sparql
        [ a sh:SPARQLConstraint ;
            rdfs:comment "Range requires both numericLowerBound and numericUpperBound."@en ;
            sh:message "qqval:Range qualifier requires both qqval:numericLowerBound and qqval:numericUpperBound."@en ;
            sh:select
                """
                PREFIX qqval: <https://growgraph.dev/ontologies/qqval-ontology#>
                SELECT $this
                WHERE {
                    $this qqval:approximationQualifier qqval:Range .
                    FILTER ( NOT EXISTS { $this qqval:numericLowerBound ?lb }
                             || NOT EXISTS { $this qqval:numericUpperBound ?ub } )
                }
                """ ;
        ] ,
        [ a sh:SPARQLConstraint ;
            rdfs:comment "AtLeast requires numericLowerBound and forbids numericUpperBound."@en ;
            sh:message "qqval:AtLeast qualifier requires qqval:numericLowerBound and must not carry qqval:numericUpperBound."@en ;
            sh:select
                """
                PREFIX qqval: <https://growgraph.dev/ontologies/qqval-ontology#>
                SELECT $this
                WHERE {
                    $this qqval:approximationQualifier qqval:AtLeast .
                    FILTER ( NOT EXISTS { $this qqval:numericLowerBound ?lb }
                             || EXISTS { $this qqval:numericUpperBound ?ub } )
                }
                """ ;
        ] ,
        [ a sh:SPARQLConstraint ;
            rdfs:comment "AtMost requires numericUpperBound and forbids numericLowerBound."@en ;
            sh:message "qqval:AtMost qualifier requires qqval:numericUpperBound and must not carry qqval:numericLowerBound."@en ;
            sh:select
                """
                PREFIX qqval: <https://growgraph.dev/ontologies/qqval-ontology#>
                SELECT $this
                WHERE {
                    $this qqval:approximationQualifier qqval:AtMost .
                    FILTER ( NOT EXISTS { $this qqval:numericUpperBound ?ub }
                             || EXISTS { $this qqval:numericLowerBound ?lb } )
                }
                """ ;
        ] ,
        [ a sh:SPARQLConstraint ;
            rdfs:comment "WithUncertainty requires a nominal value and exactly one of numericUncertainty/numericRelativeUncertainty; forbids bound properties."@en ;
            sh:message "qqval:WithUncertainty qualifier requires qudt:numericValue plus exactly one of qqval:numericUncertainty / qqval:numericRelativeUncertainty, and must not carry bound properties."@en ;
            sh:select
                """
                PREFIX qqval: <https://growgraph.dev/ontologies/qqval-ontology#>
                PREFIX qudt: <http://qudt.org/schema/qudt/>
                SELECT $this
                WHERE {
                    $this qqval:approximationQualifier qqval:WithUncertainty .
                    BIND( EXISTS { $this qqval:numericUncertainty ?u } AS ?hasAbs )
                    BIND( EXISTS { $this qqval:numericRelativeUncertainty ?r } AS ?hasRel )
                    FILTER ( NOT EXISTS { $this qudt:numericValue ?v }
                             || ( ?hasAbs = ?hasRel )
                             || EXISTS { $this qqval:numericLowerBound ?lb }
                             || EXISTS { $this qqval:numericUpperBound ?ub } )
                }
                """ ;
        ] ,
        [ a sh:SPARQLConstraint ;
            rdfs:comment "Exact/Approximate alone (no bound/uncertainty qualifier) requires a nominal value."@en ;
            sh:message "qqval:Exact / qqval:Approximate (without Range, AtLeast, AtMost, or WithUncertainty) requires qudt:numericValue."@en ;
            sh:select
                """
                PREFIX qqval: <https://growgraph.dev/ontologies/qqval-ontology#>
                PREFIX qudt: <http://qudt.org/schema/qudt/>
                SELECT $this
                WHERE {
                    $this qqval:approximationQualifier ?q .
                    FILTER ( ?q = qqval:Exact || ?q = qqval:Approximate )
                    FILTER NOT EXISTS { $this qqval:approximationQualifier qqval:Range }
                    FILTER NOT EXISTS { $this qqval:approximationQualifier qqval:AtLeast }
                    FILTER NOT EXISTS { $this qqval:approximationQualifier qqval:AtMost }
                    FILTER NOT EXISTS { $this qqval:approximationQualifier qqval:WithUncertainty }
                    FILTER NOT EXISTS { $this qudt:numericValue ?v }
                }
                """ ;
        ] .

#################################################################
# QuantityRange — structural shape
#################################################################

qqval:QuantityRangeShape a sh:NodeShape ;
    sh:targetClass qqval:QuantityRange ;
    sh:property
        [ sh:path qqval:hasLowerBound ;
            sh:maxCount 1 ;
            sh:class qudt:QuantityValue ;
            sh:message "QuantityRange allows at most one qqval:hasLowerBound."@en
        ] ,
        [ sh:path qqval:hasUpperBound ;
            sh:maxCount 1 ;
            sh:class qudt:QuantityValue ;
            sh:message "QuantityRange allows at most one qqval:hasUpperBound."@en
        ] ;
    sh:not [ sh:class qqval:ApproximateQuantityValue ] ;
    sh:sparql
        [ a sh:SPARQLConstraint ;
            rdfs:comment "At least one of hasLowerBound / hasUpperBound must be present."@en ;
            sh:message "QuantityRange requires at least one of qqval:hasLowerBound or qqval:hasUpperBound."@en ;
            sh:select
                """
                PREFIX qqval: <https://growgraph.dev/ontologies/qqval-ontology#>
                SELECT $this
                WHERE {
                    FILTER ( NOT EXISTS { $this qqval:hasLowerBound ?lb }
                             && NOT EXISTS { $this qqval:hasUpperBound ?ub } )
                }
                """ ;
        ] .
